---
import { t } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
import { getCollection } from 'astro:content';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const legalEntries = await getCollection('legal', ({ data }) => data.lang === lang);
const fallbackEntries = legalEntries.length > 0 ? legalEntries : await getCollection('legal', ({ data }) => data.lang === 'en');
const entry = fallbackEntries[0];

const lastUpdated = entry.data.lastUpdated;
const sections = entry.data.sections;
---

<section class="py-16 md:py-24 px-4 sm:px-6">
  <div class="max-w-4xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16">
      <h1 class="font-serif text-3xl md:text-5xl text-dark mb-4">{t(lang, 'legal.pageTitle')}</h1>
      <p class="text-gray-medium text-sm">{t(lang, 'legal.lastUpdated')}: {lastUpdated}</p>
    </div>

    <!-- Table of Contents -->
    <nav class="bg-gray-light/20 rounded-lg p-6 mb-16">
      <p class="text-sm font-semibold text-dark mb-3">{t(lang, 'legal.toc')}</p>
      <ul class="space-y-2">
        {sections.map((section) => (
          <li>
            <a href={`#${section.id}`} class="text-sm text-gold hover:text-gold-dark transition-colors">{section.title}</a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Sections -->
    {sections.map((section, i) => (
      <div id={section.id} class:list={['scroll-mt-24', i < sections.length - 1 && 'mb-16']}>
        <h2 class="mb-8 pb-4 border-b border-gray-light">{section.title}</h2>
        {section.subsections.map((s) => (
          <div class="mb-8">
            <h3 class="text-lg font-serif mb-3">{s.title}</h3>
            <p class="text-dark-soft text-sm leading-relaxed">{s.text}</p>
          </div>
        ))}
      </div>
    ))}
  </div>
</section>
