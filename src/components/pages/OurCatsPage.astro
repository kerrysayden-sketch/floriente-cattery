---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CatGallery from '../cats/CatGallery.astro';
import { t, getLocalizedPath, localizedBreed } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
import { getCollection } from 'astro:content';

interface Props { lang: Lang; }
const { lang } = Astro.props;

const allCats = await getCollection('cats', ({ data }) => data.lang === lang);
const cats = allCats.sort((a, b) => a.data.dob.localeCompare(b.data.dob));

const roleLabels = {
  queen: t(lang, 'ourCats.queen'),
  king: t(lang, 'ourCats.king'),
};

// Per-cat published genetic certificate (Halva's registered name is Heldig)
const certByCat: Record<string, string> = {
  sebastian: '/images/certs/genetic-sebastian.webp',
  simona: '/images/certs/genetic-simona.webp',
  halva: '/images/certs/genetic-heldig.webp',
};
---

<BaseLayout
  title={t(lang, 'pages.ourCats.title')}
  description={t(lang, 'pages.ourCats.description')}
  lang={lang}
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <div class="text-center mb-16 md:mb-24">
      <h1 class="text-dark mb-4">{t(lang, 'nav.ourCats')}</h1>
      <p class="text-dark-soft max-w-2xl mx-auto">{t(lang, 'ourCats.pageDescription')}</p>
    </div>

    {cats.map((entry, index) => {
      const cat = entry.data;
      const reversed = index % 2 === 1;
      const paragraphs = entry.body!.trim().split('\n\n');
      const isFirst = index === 0;
      const gallery = cat.gallery.map((g) => ({ src: g.src, label: t(lang, g.labelKey) }));
      const color = t(lang, `ourCats.${cat.catId}Color`);
      const certSrc = certByCat[cat.catId] ?? null;

      return (
        <section
          id={cat.catId}
          class:list={['mb-14 md:mb-20', index > 0 && 'pt-10 md:pt-14 border-t border-gray-light/30']}
        >
          <p class:list={['text-xs font-semibold uppercase tracking-[0.2em] text-gold mb-6 md:mb-8 text-center', !isFirst && 'scroll-fade']}>
            {roleLabels[cat.role]}
          </p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-start max-w-5xl mx-auto">
            <div class:list={['overflow-hidden shadow-lg group', !isFirst && (reversed ? 'scroll-fade-right' : 'scroll-fade-left'), reversed ? 'md:order-2' : 'md:order-1']}>
              <div class="aspect-[4/5] overflow-hidden bg-gray-light/20" data-lightbox-gallery={`cat-${cat.catId}`}>
                <img src={cat.mainPhoto} alt={cat.name} class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700" loading={isFirst ? 'eager' : 'lazy'} />
              </div>
            </div>

            <div class:list={['flex flex-col justify-center space-y-6', !isFirst && (reversed ? 'scroll-fade-left' : 'scroll-fade-right'), reversed ? 'md:order-1' : 'md:order-2']}>
              <div>
                <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl text-dark mb-2">{cat.name}</h2>
                {cat.titles && (
                  <span class="inline-block px-3 py-1 bg-accent-gold/10 text-accent-gold text-xs font-semibold uppercase tracking-wider">
                    {cat.titles} - World Cat Federation
                  </span>
                )}
              </div>

              <div class="space-y-4">
                {paragraphs.map((p: string) => (
                  <p class="text-dark-soft text-sm md:text-base leading-relaxed">{p}</p>
                ))}
              </div>

              <div class="grid grid-cols-2 gap-3 pt-2">
                <div class="border-l-2 border-accent-gold/30 pl-3">
                  <p class="text-[10px] text-gray-medium uppercase tracking-wider">{t(lang, 'ourCats.fieldBreed')}</p>
                  <p class="text-sm text-dark font-medium">{localizedBreed(cat.breed, cat.role, lang)}</p>
                </div>
                <div class="border-l-2 border-accent-gold/30 pl-3">
                  <p class="text-[10px] text-gray-medium uppercase tracking-wider">{t(lang, 'ourCats.fieldColor')}</p>
                  <p class="text-sm text-dark font-medium">{color}</p>
                </div>
                <div class="border-l-2 border-accent-gold/30 pl-3">
                  <p class="text-[10px] text-gray-medium uppercase tracking-wider">EMS</p>
                  <p class="text-sm text-dark font-medium">{cat.ems}</p>
                </div>
                {cat.titles && (
                  <div class="border-l-2 border-accent-gold/30 pl-3">
                    <p class="text-[10px] text-gray-medium uppercase tracking-wider">{t(lang, 'ourCats.fieldTitle')}</p>
                    <p class="text-sm text-dark font-medium">{cat.titles}</p>
                  </div>
                )}
              </div>

              <div class="bg-warm-white border border-gray-light/50 p-4 mt-2">
                <div class="flex items-start gap-3">
                  <span class="text-lg">🔬</span>
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-wider text-dark mb-1">{t(lang, 'ourCats.healthTesting')}</p>
                    {certSrc ? (
                      <>
                        <p class="text-xs text-gray-medium">{t(lang, 'ourCats.healthResultsClean')}</p>
                        <p class="text-xs text-gray-medium">{t(lang, 'ourCats.healthLabs')}</p>
                        <button
                          type="button"
                          data-cert-open
                          data-cert-src={certSrc}
                          class="mt-1.5 inline-flex items-center gap-1 text-xs font-medium text-gold hover:text-gold-dark underline underline-offset-2 cursor-pointer"
                        >
                          {t(lang, 'ourCats.healthViewCert')}
                          <span aria-hidden="true">→</span>
                        </button>
                      </>
                    ) : (
                      <>
                        <p class="text-xs text-gray-medium">{t(lang, 'ourCats.healthResultsExpected')}</p>
                        <p class="text-xs text-gray-medium">{t(lang, 'ourCats.healthLabs')}</p>
                      </>
                    )}
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="mt-8 md:mt-12 max-w-5xl mx-auto scroll-fade">
            <CatGallery photos={gallery} catName={cat.name} galleryId={cat.catId} />
          </div>
        </section>
      );
    })}

    <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8 md:mt-12 pt-12 border-t border-gray-light/30">
      <a href={getLocalizedPath('/kittens/', lang)} class="inline-block px-8 py-3 bg-gold text-warm-white font-medium hover:bg-gold-dark transition-colors text-sm uppercase tracking-wider text-center">{t(lang, 'home.ctaMeetKittens')}</a>
      <a href={getLocalizedPath('/how-to-buy/', lang)} class="inline-block px-8 py-3 border border-gold text-gold font-medium hover:bg-gold hover:text-warm-white transition-colors text-sm uppercase tracking-wider text-center">{t(lang, 'home.ctaReserve')}</a>
    </div>
  </div>

  <!-- Genetic certificate lightbox (click "View certificate" in a cat's health block) -->
  <div id="cat-cert-lightbox" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/80 p-4" role="dialog" aria-modal="true" aria-label="Certificate">
    <button id="cat-cert-close" aria-label="Close" class="absolute top-3 right-5 text-white/70 hover:text-white text-4xl leading-none z-10">&times;</button>
    <div class="relative max-w-3xl w-full flex items-center justify-center">
      <img id="cat-cert-img" src="" alt="Genetic test certificate" class="max-w-full max-h-[88vh] object-contain rounded shadow-2xl" />
    </div>
  </div>
</BaseLayout>

<style>
  .scroll-fade-left { opacity: 0; transform: translateX(-40px); transition: opacity 0.8s ease, transform 0.8s ease; }
  .scroll-fade-right { opacity: 0; transform: translateX(40px); transition: opacity 0.8s ease, transform 0.8s ease; }
  .scroll-fade-left.visible, .scroll-fade-right.visible { opacity: 1; transform: translateX(0); }
</style>

<script>
  import '../../scripts/scroll-fade';

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) entry.target.classList.add('visible');
      });
    },
    { threshold: 0.05 }
  );

  document.querySelectorAll('.scroll-fade-left, .scroll-fade-right').forEach((el) => {
    observer.observe(el);
  });

  // Genetic certificate lightbox
  const ccLb = document.getElementById('cat-cert-lightbox');
  const ccImg = document.getElementById('cat-cert-img') as HTMLImageElement | null;
  const ccClose = document.getElementById('cat-cert-close');
  if (ccLb && ccImg && ccClose) {
    const openCC = (src: string) => {
      ccImg.setAttribute('src', src);
      ccLb.classList.remove('hidden');
      ccLb.classList.add('flex');
      document.body.style.overflow = 'hidden';
    };
    const closeCC = () => {
      ccLb.classList.add('hidden');
      ccLb.classList.remove('flex');
      ccImg.setAttribute('src', '');
      document.body.style.overflow = '';
    };
    document.querySelectorAll('[data-cert-open]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const src = btn.getAttribute('data-cert-src');
        if (src) openCC(src);
      });
    });
    ccClose.addEventListener('click', closeCC);
    ccLb.addEventListener('click', (e) => { if (e.target === ccLb) closeCC(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeCC(); });
    ccImg.addEventListener('contextmenu', (e) => e.preventDefault());
  }
</script>
