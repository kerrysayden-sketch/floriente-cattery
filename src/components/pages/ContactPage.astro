---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../contact/HeroSection.astro';
import MethodsSection from '../contact/MethodsSection.astro';
import InfoSection from '../contact/InfoSection.astro';
import { t } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
---

<BaseLayout
  title={t(lang, 'pages.contact.title')}
  description={t(lang, 'pages.contact.description')}
  lang={lang}
>
  <div class="scroll-fade"><HeroSection lang={lang} /></div>
  <div class="scroll-fade"><MethodsSection lang={lang} /></div>
  <div class="scroll-fade"><InfoSection lang={lang} /></div>
</BaseLayout>

<script>
  import '../../scripts/scroll-fade';
</script>
