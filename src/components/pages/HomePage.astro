---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../home/HeroSection.astro';
import TrustBar from '../home/TrustBar.astro';
import ProcessPreview from '../home/ProcessPreview.astro';
import ScamCallout from '../shared/ScamCallout.astro';
import TestimonialsSection from '../home/TestimonialsSection.astro';
import AboutPreview from '../home/AboutPreview.astro';
import FamilySection from '../home/FamilySection.astro';
import { t } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
---

<BaseLayout
  title={t(lang, 'pages.index.title')}
  description={t(lang, 'pages.index.description')}
  lang={lang}
>
  <HeroSection lang={lang} />
  <TrustBar lang={lang} variant="A" />
  <div class="scroll-fade"><ProcessPreview lang={lang} /></div>
  <div class="scroll-fade"><ScamCallout lang={lang} /></div>
  <div class="scroll-fade"><TestimonialsSection lang={lang} /></div>
  <div class="scroll-fade"><AboutPreview lang={lang} /></div>
  <div id="family" class="scroll-fade"><FamilySection lang={lang} /></div>
</BaseLayout>

<script>
  import '../../scripts/scroll-fade';
</script>
