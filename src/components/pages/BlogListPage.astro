---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, getLocalizedPath } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
import { getCollection } from 'astro:content';
import { fetchBlogPosts } from '../../lib/storyblok';

interface Props { lang: Lang; }
const { lang } = Astro.props;

const dateLocaleMap: Record<Lang, string> = {
  en: 'en-GB',
  uk: 'uk-UA',
  pl: 'pl-PL',
  de: 'de-DE',
  ru: 'ru-RU',
};

type ListPost = {
  slug: string;
  title: string;
  summary: string;
  category: string;
  cover: string | null;
  publishedAt: string;
  href: string;
};

const localEntries = await getCollection('blog', ({ data }) => data.lang === lang);
const localPosts: ListPost[] = localEntries.map((entry) => ({
  slug: entry.data.articleSlug,
  title: entry.data.title,
  summary: entry.data.description,
  category: entry.data.category,
  cover: entry.data.ogImage ?? null,
  publishedAt: entry.data.publishDate,
  href: getLocalizedPath(`/blog/${entry.data.articleSlug}/`, lang),
}));

let storyblokPosts: ListPost[] = [];
try {
  const sb = await fetchBlogPosts();
  storyblokPosts = sb.map((post) => ({
    slug: post.slug,
    title: post.title,
    summary: lang === 'uk' ? post.summary_uk : post.summary_en,
    category: post.category,
    cover: post.cover?.filename ?? null,
    publishedAt: post.published_at,
    href: getLocalizedPath(`/blog/${post.slug}/`, lang),
  }));
} catch {
  storyblokPosts = [];
}

const seenSlugs = new Set(localPosts.map((p) => p.slug));
const merged: ListPost[] = [
  ...localPosts,
  ...storyblokPosts.filter((p) => !seenSlugs.has(p.slug)),
];

merged.sort((a, b) => (b.publishedAt ?? '').localeCompare(a.publishedAt ?? ''));

const posts = merged;
const hasPosts = posts.length > 0;
const dateLocale = dateLocaleMap[lang] ?? 'en-GB';
---

<BaseLayout
  title={t(lang, 'pages.blog.title')}
  description={t(lang, 'pages.blog.description')}
  lang={lang}
>
  <section class="py-16 md:py-24 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <h1 class="font-serif text-3xl md:text-5xl text-dark mb-6">{t(lang, 'blog.heroTitle')}</h1>
        <p class="text-dark-soft text-lg leading-relaxed max-w-2xl mx-auto">
          {t(lang, 'blog.heroText')}
        </p>
      </div>

      {hasPosts ? (
        <div class="space-y-8">
          {posts.map((post) => {
            const date = post.publishedAt
              ? new Date(post.publishedAt).toLocaleDateString(dateLocale, { year: 'numeric', month: 'long', day: 'numeric' })
              : '';
            return (
              <a href={post.href} class="group block">
                <article class="flex flex-col md:flex-row gap-6 bg-warm-white border border-gray-light rounded-lg overflow-hidden hover:border-gold/30 transition-colors">
                  <div class="md:w-1/3 aspect-[16/9] md:aspect-auto overflow-hidden bg-dark flex items-center justify-center p-6">
                    <img
                      src="/images/floriente_white_transparent.webp"
                      alt="Floriente Cattery"
                      class="w-2/3 max-w-[180px] opacity-90 group-hover:opacity-100 group-hover:scale-105 transition-all duration-300"
                      loading="lazy"
                    />
                  </div>
                  <div class="flex-1 p-6 md:py-8">
                    {post.category && (
                      <span class="text-xs uppercase tracking-wider text-gold font-semibold">{post.category}</span>
                    )}
                    <h2 class="font-serif text-xl mt-1 mb-3 group-hover:text-gold transition-colors">{post.title}</h2>
                    {post.summary && <p class="text-dark-soft text-sm leading-relaxed mb-4">{post.summary}</p>}
                    <div class="flex items-center justify-between">
                      {date && <time class="text-xs text-gray-medium">{date}</time>}
                      <span class="text-sm text-gold group-hover:text-gold-dark transition-colors inline-flex items-center gap-1">
                        {t(lang, 'blog.readMore')}
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M5 12h14M12 5l7 7-7 7" />
                        </svg>
                      </span>
                    </div>
                  </div>
                </article>
              </a>
            );
          })}
        </div>
      ) : (
        <div class="text-center py-16">
          <svg class="w-16 h-16 text-gold/20 mx-auto mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
          </svg>
          <h2 class="font-serif text-xl mb-3">{t(lang, 'blog.emptyTitle')}</h2>
          <p class="text-dark-soft max-w-md mx-auto">{t(lang, 'blog.emptyText')}</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  import '../../scripts/scroll-fade';
</script>
