---
import { t, getLocalizedPath } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="py-12 md:py-16 px-4 sm:px-6">
  <div class="max-w-5xl mx-auto">
    <div class="flex flex-col sm:flex-row items-center gap-6 md:gap-10">
      <!-- Compact photo -->
      <div class="flex-shrink-0">
        <div class="w-28 h-28 md:w-36 md:h-36 rounded-full overflow-hidden border-2 border-gold/20">
          <img
            src="/images/elvira-portrait.jpg"
            alt="Elvira — founder of Floriente Cattery"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Text -->
      <div class="text-center sm:text-left">
        <h3 class="font-serif text-xl md:text-2xl text-dark mb-2">{t(lang, 'home.aboutTitle')}</h3>
        <p class="text-dark-soft text-sm md:text-base leading-relaxed mb-4 max-w-xl">
          {lang === 'en'
            ? 'Floriente Cattery was born from a deep love for Oriental and Siamese cats. Our founder Elvira has dedicated years to understanding these extraordinary breeds — raising every kitten at home, with love and daily interaction.'
            : 'Розплідник Floriente народився з глибокої любові до орієнтальних та сіамських котів. Наша засновниця Ельвіра присвятила роки вивченню цих надзвичайних порід — виховуючи кожне кошеня вдома, з любов\'ю та щоденною увагою.'}
        </p>
        <a
          href={getLocalizedPath('/about/', lang)}
          class="inline-flex items-center gap-2 text-sm text-gold hover:text-gold-dark transition-colors font-medium"
        >
          {t(lang, 'home.aboutCta')}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
