---
import { t, getLocalizedPath } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="py-16 md:py-20 px-4 sm:px-6 bg-gray-light/20">
  <div class="max-w-5xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-5 gap-8 md:gap-12 items-center">
      <!-- Photo - 2 columns on desktop -->
      <div class="md:col-span-2">
        <div class="aspect-[3/4] overflow-hidden max-w-[280px] mx-auto md:max-w-none">
          <img
            src="/images/elvira-portrait.webp"
            alt="Elvira - founder of Floriente Cattery"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Text - 3 columns on desktop -->
      <div class="md:col-span-3 text-center md:text-left">
        <h2 class="font-serif text-2xl md:text-3xl text-dark mb-4">{t(lang, 'home.aboutTitle')}</h2>
        <p class="text-dark-soft text-sm md:text-base leading-relaxed mb-6">{t(lang, 'home.aboutParagraph1')}</p>
        <p class="text-dark-soft text-sm md:text-base leading-relaxed mb-6">{t(lang, 'home.aboutParagraph2')}</p>
        <p class="text-dark-soft text-sm md:text-base leading-relaxed mb-6">{t(lang, 'home.aboutParagraph3')}</p>
        <a
          href={getLocalizedPath('/about/', lang)}
          class="inline-block px-6 py-2.5 border border-gold text-gold font-medium hover:bg-gold hover:text-warm-white transition-colors text-sm uppercase tracking-wider"
        >
          {t(lang, 'home.aboutCta')}
        </a>
      </div>
    </div>
  </div>
</section>
