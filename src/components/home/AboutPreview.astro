---
import { t, getLocalizedPath } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="py-16 md:py-24 px-4 sm:px-6 bg-gray-light/20">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <!-- Photo placeholder -->
      <div class="order-2 md:order-1">
        <div class="aspect-[4/5] rounded-lg overflow-hidden">
          <img
            src="/images/elvira-portrait.jpg"
            alt="Elvira — founder of Floriente Cattery"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Text -->
      <div class="order-1 md:order-2">
        <h2 class="mb-6">{t(lang, 'home.aboutTitle')}</h2>
        <p class="text-dark-soft leading-relaxed mb-8">
          {t(lang, 'home.aboutText')}
        </p>
        <a
          href={getLocalizedPath('/about/', lang)}
          class="inline-block px-8 py-3 border border-gold text-gold font-medium rounded hover:bg-gold hover:text-warm-white transition-colors text-sm uppercase tracking-wider"
        >
          {t(lang, 'home.aboutCta')}
        </a>
      </div>
    </div>
  </div>
</section>
