---
import { t, getLocalizedPath } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="py-16 md:py-24 px-4 sm:px-6 bg-gray-light/20">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <!-- Photo placeholder -->
      <div class="order-2 md:order-1">
        <div class="aspect-[4/5] rounded-lg bg-gray-light/50 flex items-center justify-center overflow-hidden">
          <!-- TODO: Replace with Elvira's photo -->
          <svg class="w-16 h-16 text-gold/30" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </div>
      </div>

      <!-- Text -->
      <div class="order-1 md:order-2">
        <h2 class="mb-6">{t(lang, 'home.aboutTitle')}</h2>
        <p class="text-dark-soft leading-relaxed mb-8">
          {t(lang, 'home.aboutText')}
        </p>
        <a
          href={getLocalizedPath('/about/', lang)}
          class="inline-block px-8 py-3 border border-gold text-gold font-medium rounded hover:bg-gold hover:text-warm-white transition-colors text-sm uppercase tracking-wider"
        >
          {t(lang, 'home.aboutCta')}
        </a>
      </div>
    </div>
  </div>
</section>
