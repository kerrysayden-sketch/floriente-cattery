---
import { t, getLocalizedPath } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
import { fetchKittens } from '../../lib/storyblok';
import KittenCard from '../cats/KittenCard.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

let availableKittens: any[] = [];
try {
  const allKittens = await fetchKittens();
  availableKittens = allKittens.filter((k) => k.status === 'available').slice(0, 3);
} catch {
  // CMS unavailable
}
---

<section class="py-16 md:py-24 px-4 sm:px-6">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-center mb-4">{t(lang, 'home.kittensTitle')}</h2>

    {availableKittens.length > 0 ? (
      <>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 mt-12">
          {availableKittens.map((kitten) => <KittenCard kitten={kitten} lang={lang} />)}
        </div>
        <div class="text-center mt-10">
          <a
            href={getLocalizedPath('/kittens/', lang)}
            class="inline-block px-8 py-3 border border-gold text-gold font-medium rounded hover:bg-gold hover:text-warm-white transition-colors text-sm uppercase tracking-wider"
          >
            {t(lang, 'common.viewAll')}
          </a>
        </div>
      </>
    ) : (
      <div class="text-center mt-8 max-w-lg mx-auto">
        <div class="w-32 h-32 mx-auto mb-6 rounded-full overflow-hidden border-2 border-gold/20">
          <img
            src="/images/cats/simona-main.jpg"
            alt="Oriental cat"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <p class="text-dark-soft text-lg mb-2">{t(lang, 'home.kittensEmpty')}</p>
        <p class="text-gray-medium text-sm mb-8">{t(lang, 'home.kittensWaitlist')}</p>
        <a
          href={getLocalizedPath('/contact/', lang)}
          class="inline-block px-8 py-3 bg-gold text-warm-white font-medium hover:bg-gold-dark transition-colors text-sm uppercase tracking-wider"
        >
          {t(lang, 'home.kittensJoinWaitlist')}
        </a>
      </div>
    )}
  </div>
</section>
