---
import { t, getLocalizedPath } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="relative flex flex-col items-center justify-center min-h-[85vh] px-6 text-center overflow-hidden">
  <!-- Background video — plays behind everything -->
  <video
    id="hero-video"
    class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-1000 -z-10"
    poster="/images/floriente_dark_navy_transparent.png"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
  >
    <source src="/videos/hero.mp4" type="video/mp4" />
  </video>

  <!-- Warm overlay for text readability when video plays -->
  <div id="hero-overlay" class="absolute inset-0 bg-gradient-to-b from-warm-white/40 via-warm-white/60 to-warm-white/85 opacity-0 transition-opacity duration-1000 -z-10"></div>

  <!-- Background fallback gradient (visible before video loads) -->
  <div class="absolute inset-0 bg-gradient-to-b from-warm-white via-warm-white to-gray-light/30 -z-20"></div>

  <!-- Logo — visible initially, fades out when video plays -->
  <div id="hero-logo" class="mb-10 animate-fade-in transition-opacity duration-1000">
    <img
      src="/images/floriente_dark_navy_transparent.png"
      alt={t(lang, 'pages.logoAlt')}
      class="w-56 md:w-72 lg:w-80 h-auto mx-auto"
    />
  </div>

  <!-- Headline -->
  <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl text-gold-dark mb-4 animate-fade-in-delay-1 relative">
    {t(lang, 'home.heroHeadline')}
  </h1>

  <!-- Subheadline -->
  <p class="text-lg md:text-xl text-dark-soft max-w-xl mx-auto mb-10 animate-fade-in-delay-2 relative">
    {t(lang, 'home.heroSubheadline')}
  </p>

  <!-- CTA Buttons -->
  <div class="flex flex-col sm:flex-row gap-4 animate-fade-in-delay-3 relative">
    <a
      href={getLocalizedPath('/kittens/', lang)}
      class="inline-block px-8 py-3.5 bg-gold text-warm-white font-medium rounded hover:bg-gold-dark transition-colors text-sm uppercase tracking-wider"
    >
      {t(lang, 'home.ctaMeetKittens')}
    </a>
    <a
      href={getLocalizedPath('/how-to-buy/', lang)}
      class="inline-block px-8 py-3.5 border border-gold text-gold font-medium rounded hover:bg-gold hover:text-warm-white transition-colors text-sm uppercase tracking-wider"
    >
      {t(lang, 'home.ctaReserve')}
    </a>
  </div>
</section>

<script>
  // Progressive enhancement: show video when ready, fade out logo
  const video = document.getElementById('hero-video') as HTMLVideoElement | null;
  const overlay = document.getElementById('hero-overlay');
  const logo = document.getElementById('hero-logo');

  if (video && overlay && logo) {
    video.addEventListener('canplaythrough', () => {
      video.style.opacity = '1';
      overlay.style.opacity = '1';
      logo.style.opacity = '0';
      // Keep logo in DOM for layout, just invisible
      setTimeout(() => {
        if (logo) logo.style.visibility = 'hidden';
      }, 1000);
    }, { once: true });

    // If video fails to load — keep logo visible (graceful fallback)
    video.addEventListener('error', () => {
      video.style.display = 'none';
    });
  }
</script>
