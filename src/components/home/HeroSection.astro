---
import { t, getLocalizedPath } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section id="hero" class="relative flex flex-col items-center justify-center min-h-[85vh] px-6 text-center overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-warm-white via-warm-white to-gray-light/30"></div>

  <!-- Background video -->
  <video
    id="hero-video"
    class="absolute inset-0 w-full h-full object-cover hero-video"
    muted
    playsinline
    preload="auto"
  >
    <source src="/videos/hero.mp4" type="video/mp4" />
  </video>

  <!-- Warm overlay -->
  <div class="absolute inset-0 hero-overlay bg-gradient-to-b from-warm-white/40 via-warm-white/50 to-warm-white/85"></div>

  <!-- Logo -->
  <div class="relative mb-10 animate-fade-in hero-fade-element">
    <img
      src="/images/floriente_dark_navy_transparent.png"
      alt={t(lang, 'pages.logoAlt')}
      class="w-56 md:w-72 lg:w-80 h-auto mx-auto"
    />
  </div>

  <!-- Headline -->
  <h1 class="relative font-serif text-4xl md:text-5xl lg:text-6xl text-gold-dark mb-4 animate-fade-in-delay-1 hero-fade-element">
    {t(lang, 'home.heroHeadline')}
  </h1>

  <!-- Subheadline -->
  <p class="relative text-lg md:text-xl text-dark-soft max-w-xl mx-auto mb-10 animate-fade-in-delay-2 hero-fade-element">
    {t(lang, 'home.heroSubheadline')}
  </p>

  <!-- CTA Buttons -->
  <div class="relative flex flex-col sm:flex-row gap-4 animate-fade-in-delay-3">
    <a
      href={getLocalizedPath('/kittens/', lang)}
      class="inline-block px-8 py-3.5 bg-gold text-warm-white font-medium rounded hover:bg-gold-dark transition-colors text-sm uppercase tracking-wider"
    >
      {t(lang, 'home.ctaMeetKittens')}
    </a>
    <a
      href={getLocalizedPath('/how-to-buy/', lang)}
      class="inline-block px-8 py-3.5 border border-gold text-gold font-medium rounded hover:bg-gold hover:text-warm-white transition-colors text-sm uppercase tracking-wider"
    >
      {t(lang, 'home.ctaReserve')}
    </a>
  </div>
</section>

<style>
  /* Video & overlay — hidden by default */
  .hero-video {
    opacity: 0;
    transition: opacity 1.5s ease;
  }
  .hero-overlay {
    opacity: 0;
    transition: opacity 1.5s ease;
  }

  /* Logo, headline, subheadline — fade transition */
  .hero-fade-element {
    transition: opacity 1.5s ease;
  }

  /* When video is playing — class on section triggers all transitions */
  #hero.video-playing .hero-video {
    opacity: 1;
  }
  #hero.video-playing .hero-overlay {
    opacity: 1;
  }
  #hero.video-playing .hero-fade-element {
    opacity: 0.1 !important;
  }
</style>

<script>
  const hero = document.getElementById('hero');
  const video = document.getElementById('hero-video') as HTMLVideoElement | null;

  if (hero && video) {
    const DELAY_BEFORE_START = 1000;
    const PAUSE_BETWEEN_LOOPS = 5000;

    function playVideo() {
      video!.currentTime = 0;
      video!.play().then(() => {
        hero!.classList.add('video-playing');
      }).catch(() => {
        // autoplay blocked — keep logo
      });
    }

    function onVideoEnded() {
      hero!.classList.remove('video-playing');
      setTimeout(playVideo, PAUSE_BETWEEN_LOOPS);
    }

    video.addEventListener('ended', onVideoEnded);

    // Start first cycle
    let started = false;
    function startCycle() {
      if (started) return;
      started = true;
      setTimeout(playVideo, DELAY_BEFORE_START);
    }

    video.addEventListener('loadeddata', startCycle, { once: true });
    video.addEventListener('canplay', startCycle, { once: true });
    setTimeout(() => { if (!started) startCycle(); }, 3000);

    video.addEventListener('error', () => {
      hero!.classList.remove('video-playing');
    });
  }
</script>
