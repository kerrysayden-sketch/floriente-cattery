---
import { t, getLocalizedPath } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="relative flex flex-col items-center justify-center min-h-[85vh] px-6 text-center">
  <!-- Background subtle gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-warm-white via-warm-white to-gray-light/30 -z-10"></div>

  <!-- Logo as hero (placeholder for future animation) -->
  <div class="mb-10 animate-fade-in">
    <img
      src="/images/floriente_dark_navy_transparent.png"
      alt={t(lang, 'pages.logoAlt')}
      class="w-56 md:w-72 lg:w-80 h-auto mx-auto"
    />
  </div>

  <!-- Headline -->
  <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl text-gold-dark mb-4 animate-fade-in-delay-1">
    {t(lang, 'home.heroHeadline')}
  </h1>

  <!-- Subheadline -->
  <p class="text-lg md:text-xl text-dark-soft max-w-xl mx-auto mb-10 animate-fade-in-delay-2">
    {t(lang, 'home.heroSubheadline')}
  </p>

  <!-- CTA Buttons -->
  <div class="flex flex-col sm:flex-row gap-4 animate-fade-in-delay-3">
    <a
      href={getLocalizedPath('/kittens/', lang)}
      class="inline-block px-8 py-3.5 bg-gold text-warm-white font-medium rounded hover:bg-gold-dark transition-colors text-sm uppercase tracking-wider"
    >
      {t(lang, 'home.ctaMeetKittens')}
    </a>
    <a
      href={getLocalizedPath('/how-to-buy/', lang)}
      class="inline-block px-8 py-3.5 border border-gold text-gold font-medium rounded hover:bg-gold hover:text-warm-white transition-colors text-sm uppercase tracking-wider"
    >
      {t(lang, 'home.ctaReserve')}
    </a>
  </div>
</section>
