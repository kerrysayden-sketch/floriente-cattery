---
import { t, getLocalizedPath } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="relative flex flex-col items-center justify-center min-h-[85vh] px-6 text-center overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-warm-white via-warm-white to-gray-light/30"></div>

  <!-- Background video — hidden initially -->
  <video
    id="hero-video"
    class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-1500"
    muted
    playsinline
    preload="auto"
  >
    <source src="/videos/hero.mp4" type="video/mp4" />
  </video>

  <!-- Warm overlay for text readability -->
  <div id="hero-overlay" class="absolute inset-0 bg-gradient-to-b from-warm-white/40 via-warm-white/50 to-warm-white/85 opacity-0 transition-opacity duration-1500"></div>

  <!-- Logo -->
  <div id="hero-logo" class="relative mb-10 animate-fade-in transition-opacity duration-1500">
    <img
      src="/images/floriente_dark_navy_transparent.png"
      alt={t(lang, 'pages.logoAlt')}
      class="w-56 md:w-72 lg:w-80 h-auto mx-auto"
    />
  </div>

  <!-- Headline -->
  <h1 class="relative font-serif text-4xl md:text-5xl lg:text-6xl text-gold-dark mb-4 animate-fade-in-delay-1">
    {t(lang, 'home.heroHeadline')}
  </h1>

  <!-- Subheadline -->
  <p class="relative text-lg md:text-xl text-dark-soft max-w-xl mx-auto mb-10 animate-fade-in-delay-2">
    {t(lang, 'home.heroSubheadline')}
  </p>

  <!-- CTA Buttons -->
  <div class="relative flex flex-col sm:flex-row gap-4 animate-fade-in-delay-3">
    <a
      href={getLocalizedPath('/kittens/', lang)}
      class="inline-block px-8 py-3.5 bg-gold text-warm-white font-medium rounded hover:bg-gold-dark transition-colors text-sm uppercase tracking-wider"
    >
      {t(lang, 'home.ctaMeetKittens')}
    </a>
    <a
      href={getLocalizedPath('/how-to-buy/', lang)}
      class="inline-block px-8 py-3.5 border border-gold text-gold font-medium rounded hover:bg-gold hover:text-warm-white transition-colors text-sm uppercase tracking-wider"
    >
      {t(lang, 'home.ctaReserve')}
    </a>
  </div>
</section>

<style>
  .transition-opacity {
    transition-property: opacity;
  }
  .duration-1500 {
    transition-duration: 1500ms;
  }
</style>

<script>
  const video = document.getElementById('hero-video') as HTMLVideoElement | null;
  const overlay = document.getElementById('hero-overlay');
  const logo = document.getElementById('hero-logo');

  if (video && overlay && logo) {
    const DELAY_BEFORE_START = 2000;  // 2s static logo before first play
    const PAUSE_BETWEEN_LOOPS = 5000; // 5s pause with logo between loops

    function showVideo() {
      video!.currentTime = 0;
      video!.play();
      video!.style.opacity = '1';
      overlay!.style.opacity = '1';
      logo!.style.opacity = '0.15';
    }

    function hideVideo() {
      video!.style.opacity = '0';
      overlay!.style.opacity = '0';
      logo!.style.opacity = '1';
    }

    // When video ends — fade out, show logo, wait, repeat
    video.addEventListener('ended', () => {
      hideVideo();
      setTimeout(showVideo, PAUSE_BETWEEN_LOOPS);
    });

    // First play after initial delay
    video.addEventListener('canplaythrough', () => {
      setTimeout(showVideo, DELAY_BEFORE_START);
    }, { once: true });

    // Fallback: if video fails — logo stays
    video.addEventListener('error', () => {
      logo!.style.opacity = '1';
    });
  }
</script>
