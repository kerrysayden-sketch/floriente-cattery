---
import { t, getLocalizedPath } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const alumni = [
  { name: 'Buddy', src: '/images/family/buddy.jpg' },
  { name: 'Barbie', src: '/images/family/barbie.jpg' },
  { name: 'Al-Muad Dib Salma', src: '/images/family/al-muad-dib-salma.jpg' },
  { name: 'Asya', src: '/images/family/asya.jpg' },
  { name: 'Axel Cornelius', src: '/images/family/axel-cornelius.jpg' },
  { name: 'Bantik', src: '/images/family/bantik.jpg' },
  { name: 'Alt Milky', src: '/images/family/alt-milky.jpg' },
  { name: 'Astra Shakhty', src: '/images/family/astra-shakhty.jpg' },
  { name: 'Bars', src: '/images/family/bars.jpg' },
  { name: 'Barton', src: '/images/family/barton.jpg' },
  { name: 'Bead', src: '/images/family/bead.jpg' },
  { name: 'Benjamin', src: '/images/family/benjamin.jpg' },
  { name: 'Bill', src: '/images/family/bill.jpg' },
];
---

<section class="py-16 md:py-24 px-4 sm:px-6">
  <div class="max-w-6xl mx-auto text-center">
    <h2 class="mb-2">{t(lang, 'home.familyTitle')}</h2>
    <p class="text-gray-medium mb-12">{t(lang, 'home.familySubtitle')}</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
      {alumni.map((kitten) => (
        <div class="group">
          <div class="aspect-square rounded-lg overflow-hidden" data-lightbox-gallery="home-family">
            <img
              src={kitten.src}
              alt={kitten.name}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
          <p class="text-sm font-serif text-dark mt-2">{kitten.name}</p>
        </div>
      ))}
    </div>

    <a
      href={getLocalizedPath('/kittens/', lang)}
      class="inline-flex items-center gap-2 px-6 py-3 border border-gray-light rounded-sm text-sm text-dark-soft hover:border-gold hover:text-gold transition-colors"
    >
      {t(lang, 'home.ctaMeetKittens')}
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14M12 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</section>
