---
// Lightbox component — activated via JS when clicking gallery images
// Supports: prev/next arrows, keyboard navigation, swipe on mobile
---

<div
  id="lightbox"
  class="fixed inset-0 z-[80] bg-dark/90 hidden items-center justify-center"
  role="dialog"
  aria-modal="true"
  aria-label="Photo viewer"
>
  <!-- Close -->
  <button
    id="lightbox-close"
    class="absolute top-4 right-4 text-warm-white/80 hover:text-warm-white z-10 p-2"
    aria-label="Close"
  >
    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <!-- Previous -->
  <button
    id="lightbox-prev"
    class="absolute left-2 md:left-6 top-1/2 -translate-y-1/2 text-warm-white/60 hover:text-warm-white z-10 p-3 hidden"
    aria-label="Previous"
  >
    <svg class="w-8 h-8 md:w-10 md:h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
    </svg>
  </button>

  <!-- Next -->
  <button
    id="lightbox-next"
    class="absolute right-2 md:right-6 top-1/2 -translate-y-1/2 text-warm-white/60 hover:text-warm-white z-10 p-3 hidden"
    aria-label="Next"
  >
    <svg class="w-8 h-8 md:w-10 md:h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  </button>

  <!-- Counter -->
  <div id="lightbox-counter" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-warm-white/60 text-sm hidden"></div>

  <!-- Image -->
  <img
    id="lightbox-img"
    src=""
    alt=""
    class="max-w-[90vw] max-h-[85vh] object-contain rounded select-none"
  />
</div>

<script>
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxClose = document.getElementById('lightbox-close');
  const lightboxPrev = document.getElementById('lightbox-prev');
  const lightboxNext = document.getElementById('lightbox-next');
  const lightboxCounter = document.getElementById('lightbox-counter');

  let gallery: HTMLImageElement[] = [];
  let currentIndex = 0;

  function showImage(index: number) {
    if (index < 0 || index >= gallery.length) return;
    currentIndex = index;
    lightboxImg!.src = gallery[index].src;
    lightboxImg!.alt = gallery[index].alt;

    // Show/hide nav buttons
    const hasMultiple = gallery.length > 1;
    lightboxPrev?.classList.toggle('hidden', !hasMultiple);
    lightboxNext?.classList.toggle('hidden', !hasMultiple);
    lightboxCounter?.classList.toggle('hidden', !hasMultiple);

    if (hasMultiple && lightboxCounter) {
      lightboxCounter.textContent = `${index + 1} / ${gallery.length}`;
    }

    // Dim arrows at edges
    lightboxPrev?.classList.toggle('opacity-30', index === 0);
    lightboxNext?.classList.toggle('opacity-30', index === gallery.length - 1);
  }

  function openLightbox(clickedImg: HTMLImageElement) {
    if (!lightbox || !lightboxImg) return;

    // Build gallery from images in the same section/container
    const section = clickedImg.closest('section, .grid, div[class*="grid"]');
    const imagesInSection = section
      ? Array.from(section.querySelectorAll('[data-lightbox]')) as HTMLImageElement[]
      : [clickedImg];

    gallery = imagesInSection.length > 0 ? imagesInSection : [clickedImg];
    currentIndex = gallery.indexOf(clickedImg);
    if (currentIndex === -1) currentIndex = 0;

    showImage(currentIndex);
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    if (!lightbox) return;
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    document.body.style.overflow = '';
    gallery = [];
  }

  function prevImage() {
    if (currentIndex > 0) showImage(currentIndex - 1);
  }

  function nextImage() {
    if (currentIndex < gallery.length - 1) showImage(currentIndex + 1);
  }

  // Click on gallery images to open
  document.querySelectorAll('[data-lightbox]').forEach((el) => {
    el.addEventListener('click', () => openLightbox(el as HTMLImageElement));
  });

  // Close on click overlay (not on image or buttons)
  lightbox?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target === lightbox) closeLightbox();
  });

  lightboxClose?.addEventListener('click', closeLightbox);
  lightboxPrev?.addEventListener('click', (e) => { e.stopPropagation(); prevImage(); });
  lightboxNext?.addEventListener('click', (e) => { e.stopPropagation(); nextImage(); });

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (!lightbox || lightbox.classList.contains('hidden')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') prevImage();
    if (e.key === 'ArrowRight') nextImage();
  });

  // Swipe support for mobile
  let touchStartX = 0;
  let touchEndX = 0;

  lightbox?.addEventListener('touchstart', (e) => {
    touchStartX = (e as TouchEvent).changedTouches[0].screenX;
  }, { passive: true });

  lightbox?.addEventListener('touchend', (e) => {
    touchEndX = (e as TouchEvent).changedTouches[0].screenX;
    const diff = touchStartX - touchEndX;
    if (Math.abs(diff) > 50) {
      if (diff > 0) nextImage();
      else prevImage();
    }
  }, { passive: true });

  // Prevent image click from closing
  lightboxImg?.addEventListener('click', (e) => e.stopPropagation());
</script>
