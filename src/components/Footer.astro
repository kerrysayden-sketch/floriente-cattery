---
import { t, getLocalizedPath, languages } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const otherLang = lang === 'en' ? 'uk' : 'en';
const switchPath = getLocalizedPath(
  Astro.url.pathname.replace(/^\/(en|uk)/, ''),
  otherLang as Lang,
);

const quickLinks = [
  { key: 'nav.kittens', path: '/kittens/' },
  { key: 'nav.howToBuy', path: '/how-to-buy/' },
  { key: 'nav.ourCats', path: '/our-cats/' },
  { key: 'nav.faq', path: '/faq/' },
  { key: 'nav.contact', path: '/contact/' },
  { key: 'nav.about', path: '/about/' },
];

const legalLinks = [
  { key: 'footer.privacy', path: '/legal/#privacy' },
  { key: 'footer.cookies', path: '/legal/#cookies' },
  { key: 'footer.terms', path: '/legal/#terms' },
];
---

<footer class="bg-dark text-warm-white/80">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand -->
      <div>
        <a href={getLocalizedPath('/', lang)} class="inline-block mb-4" aria-label="Floriente Cattery">
          <img
            src="/images/floriente_white_transparent.png"
            alt="Floriente Cattery"
            class="h-12 w-auto brightness-150 contrast-125"
          />
        </a>
        <a href="/images/certs/wcf-registration-full.jpg" target="_blank" class="block text-sm leading-relaxed text-warm-white/60 hover:text-gold transition-colors">
          {t(lang, 'footer.wcf')}
        </a>
        <p class="text-sm mt-2 text-warm-white/60">
          {t(lang, 'footer.location')}
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider text-warm-white mb-4">
          {t(lang, 'footer.quickLinks')}
        </h4>
        <ul class="space-y-2">
          {quickLinks.map((item) => (
            <li>
              <a
                href={getLocalizedPath(item.path, lang)}
                class="text-sm text-warm-white/60 hover:text-gold transition-colors"
              >
                {t(lang, item.key)}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact & Social -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider text-warm-white mb-4">
          {t(lang, 'footer.contacts')}
        </h4>
        <ul class="space-y-2">
          <li>
            <a
              href="mailto:info@florientecattery.com"
              class="text-sm text-warm-white/60 hover:text-gold transition-colors"
            >
              {t(lang, 'footer.email')}
            </a>
          </li>
        </ul>
        <h4 class="text-sm font-semibold uppercase tracking-wider text-warm-white mt-6 mb-4">
          {t(lang, 'footer.followUs')}
        </h4>
        <div class="flex gap-3">
          <a href="https://www.instagram.com/floriente_orientals_cattery" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-warm-white/10 flex items-center justify-center hover:bg-gold/20 transition-colors" aria-label="Instagram">
            <svg class="w-4 h-4 text-warm-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          <a href="https://www.facebook.com/elvira.naurzalina" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-warm-white/10 flex items-center justify-center hover:bg-gold/20 transition-colors" aria-label="Facebook">
            <svg class="w-4 h-4 text-warm-white/60" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <a href="https://www.tiktok.com/@floriente_cattery" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-warm-white/10 flex items-center justify-center hover:bg-gold/20 transition-colors" aria-label="TikTok">
            <svg class="w-4 h-4 text-warm-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Legal + Language -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider text-warm-white mb-4">
          {t(lang, 'nav.legal')}
        </h4>
        <ul class="space-y-2">
          {legalLinks.map((item) => (
            <li>
              <a
                href={getLocalizedPath(item.path, lang)}
                class="text-sm text-warm-white/60 hover:text-gold transition-colors"
              >
                {t(lang, item.key)}
              </a>
            </li>
          ))}
        </ul>
        <div class="mt-6">
          <a
            href={switchPath}
            class="inline-flex items-center gap-2 text-sm text-warm-white/60 hover:text-gold transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9" />
            </svg>
            {languages[otherLang]}
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-warm-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-warm-white/40">
        &copy; 2024–{new Date().getFullYear()} {t(lang, 'footer.copyright')}
      </p>
      <a
        href="https://wcf.de/en/cattery-names/"
        target="_blank"
        class="text-xs text-warm-white/40 hover:text-gold transition-colors"
      >
        {t(lang, 'footer.wcf')}
      </a>
    </div>
  </div>
</footer>
