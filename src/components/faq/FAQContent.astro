---
import { t, getLocalizedPath } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

interface FAQ {
  q: string;
  a: string;
}

interface FAQCategory {
  title: string;
  items: FAQ[];
}

const content: Record<string, FAQCategory[]> = {
  en: [
    {
      title: 'About the Breed',
      items: [
        {
          q: 'What is the difference between Oriental and Siamese cats?',
          a: 'Both breeds share the same elegant body type and personality. The main difference is colour: Siamese cats have a pointed coat (lighter body with darker extremities), while Orientals come in over 300 colour and pattern combinations. Both are equally intelligent, vocal, and deeply bonded to their humans.',
        },
        {
          q: 'Are Oriental and Siamese cats good with children?',
          a: 'Yes. They are sociable, patient, and enjoy interactive play. Their emotions are easy to read through voice and body language, which helps children learn to respect boundaries. They thrive in active households and often become a child\'s closest companion.',
        },
        {
          q: 'Do they get along with other pets?',
          a: 'With proper socialization, Orientals and Siamese live well with other active cats and even dogs. They see them as play partners rather than threats. We socialize our kittens with other cats from birth.',
        },
        {
          q: 'Are these cats really as vocal as people say?',
          a: 'Yes — and it\'s part of their charm. They don\'t just meow; they carry on full conversations. They comment on everything happening around them, greet you at the door, and let you know when they want attention. Most owners find it endearing rather than annoying.',
        },
        {
          q: 'Do Oriental cats need a lot of attention?',
          a: 'They are deeply people-oriented and prefer to be involved in your life. They follow you from room to room, sit on your desk while you work, and sleep next to you. If you want an independent cat that stays on its own, this is not the right breed. If you want a loyal, interactive companion — they are perfect.',
        },
      ],
    },
    {
      title: 'Purchasing & Pricing',
      items: [
        {
          q: 'How much does a kitten cost?',
          a: 'Pet class kittens are priced between 800 and 1,500 EUR depending on the individual kitten. Breed and Show class kittens are priced individually, approximately 2x the pet class price. The price includes vaccinations, microchip, veterinary passport, metrika (kitten card), and a starter kit.',
        },
        {
          q: 'What is included in the price?',
          a: 'Every kitten leaves with: 2x vaccination + rabies, microchip, veterinary passport, metrika (kitten card), spay/neuter for pet class, food for first days, toys, comfort blanket from home, and an adaptation guide.',
        },
        {
          q: 'How does the reservation process work?',
          a: 'First, write to us on WhatsApp or Instagram. We\'ll arrange a video call to get to know each other. When a litter is available, we help you choose the right kitten. You reserve with a 50% deposit and a signed contract. Then you receive regular photos and videos while your kitten grows.',
        },
        {
          q: 'Is the deposit refundable?',
          a: 'The 50% deposit is non-refundable if the buyer cancels. It is fully refundable if we are unable to provide the kitten for any reason.',
        },
        {
          q: 'Do you deliver kittens internationally?',
          a: 'Yes. We arrange personal delivery across Europe. The exact delivery method and costs are discussed individually based on your location. Kittens are never shipped alone — we deliver them personally.',
        },
      ],
    },
    {
      title: 'Health & Care',
      items: [
        {
          q: 'Are your cats health tested?',
          a: 'Yes. All breeding cats are tested for PRA, PK Deficiency, and other breed-specific genetic conditions. We never practice inbreeding. Test results are available upon request.',
        },
        {
          q: 'At what age can I take my kitten home?',
          a: 'Kittens leave at 3 months or older, fully vaccinated (including rabies), microchipped, and with a veterinary passport. We never release kittens earlier — this period is critical for socialization and immune system development.',
        },
        {
          q: 'What should I feed my Oriental or Siamese cat?',
          a: 'We provide detailed nutrition guidelines with every kitten, including the specific food they\'ve been eating. We recommend premium dry and wet food appropriate for their age. Gradual transitions are important — sudden food changes can cause digestive issues.',
        },
        {
          q: 'Do you provide support after purchase?',
          a: 'Always. Elvira stays in contact with every family for advice on adaptation, nutrition, and behaviour — anytime you need us. Many families stay in touch for years, sharing photos and milestones.',
        },
      ],
    },
    {
      title: 'About Our Cattery',
      items: [
        {
          q: 'Is Floriente a registered cattery?',
          a: 'Yes. Floriente is officially registered with the World Cat Federation (WCF), registration number 50188-2025. Our breeding cats hold Grand Inter-Champion (GIC) titles. Elvira is a certified Breeder-Felinologist.',
        },
        {
          q: 'Where are you located?',
          a: 'We are located in the Kyiv Region, Ukraine. Our cats live with us at home — not in cages or separate facilities. The exact address is shared after reservation.',
        },
        {
          q: 'How many litters do you have per year?',
          a: 'We focus on quality over quantity and have only a few litters per year. Each kitten receives individual attention, daily interaction, and proper socialization in a family environment.',
        },
        {
          q: 'Can I visit the cattery before purchasing?',
          a: 'We offer video calls where you can see our home, meet the cats, and ask any questions. For international buyers, this is the most practical option. In-person visits can be arranged after reservation.',
        },
      ],
    },
  ],
  uk: [
    {
      title: 'Про породу',
      items: [
        {
          q: 'Яка різниця між орієнтальними та сіамськими котами?',
          a: 'Обидві породи мають однаковий елегантний тип тіла та характер. Головна різниця — забарвлення: сіамські коти мають пойнтовий окрас (світліше тіло з темнішими кінцівками), тоді як орієнтали бувають понад 300 комбінацій кольорів та малюнків. Обидві породи однаково розумні, голосисті та глибоко прив\'язані до своїх людей.',
        },
        {
          q: 'Чи підходять орієнтальні та сіамські коти для дітей?',
          a: 'Так. Вони товариські, терплячі та люблять інтерактивні ігри. Їхні емоції легко читаються через голос та мову тіла, що допомагає дітям вчитися поважати межі. Вони процвітають в активних домогосподарствах і часто стають найближчим компаньйоном дитини.',
        },
        {
          q: 'Чи уживаються вони з іншими тваринами?',
          a: 'За належної соціалізації орієнтали та сіамці добре живуть з іншими активними котами і навіть собаками. Вони бачать їх як партнерів для гри, а не як загрозу. Ми соціалізуємо наших кошенят з іншими котами з народження.',
        },
        {
          q: 'Чи справді ці коти такі голосисті, як кажуть?',
          a: 'Так — і це частина їхнього шарму. Вони не просто нявкають — вони ведуть повноцінні розмови. Коментують все, що відбувається навколо, зустрічають вас біля дверей і повідомляють, коли хочуть уваги. Більшість власників вважають це чарівним.',
        },
        {
          q: 'Чи потребують орієнтальні коти багато уваги?',
          a: 'Вони глибоко орієнтовані на людей і вважають за краще бути залученими до вашого життя. Ходять за вами з кімнати в кімнату, сидять на столі поки ви працюєте, сплять поруч з вами. Якщо ви хочете незалежного кота — це не та порода. Якщо хочете вірного, інтерактивного компаньйона — вони ідеальні.',
        },
      ],
    },
    {
      title: 'Купівля та ціни',
      items: [
        {
          q: 'Скільки коштує кошеня?',
          a: 'Кошенята пет-класу коштують від 800 до 1 500 EUR залежно від конкретного кошеняти. Брід та шоу клас оцінюються індивідуально, приблизно x2 від ціни пет-класу. Ціна включає вакцинацію, мікрочіп, ветеринарний паспорт, метрику та стартовий набір.',
        },
        {
          q: 'Що входить у вартість?',
          a: 'Кожне кошеня від\'їжджає з: 2x вакцинація + сказ, мікрочіп, ветеринарний паспорт, метрику, стерилізація для пет-класу, корм на перші дні, іграшки, ковдрочка з дому та гід з адаптації.',
        },
        {
          q: 'Як працює процес бронювання?',
          a: 'Спочатку напишіть нам у WhatsApp або Instagram. Ми організуємо відеодзвінок для знайомства. Коли з\'явиться виводок, допоможемо обрати кошеня. Бронювання — депозит 50% від вартості та підписаний договір. Потім ви отримуєте регулярні фото та відео, поки кошеня росте.',
        },
        {
          q: 'Чи повертається депозит?',
          a: 'Депозит 50% не повертається при відмові покупця. Повністю повертається, якщо ми не можемо надати кошеня з будь-якої причини.',
        },
        {
          q: 'Чи доставляєте ви кошенят за кордон?',
          a: 'Так. Ми організовуємо особисту доставку по всій Європі. Точний спосіб доставки та вартість обговорюються індивідуально. Кошенят ніколи не відправляють одних — ми доставляємо їх особисто.',
        },
      ],
    },
    {
      title: "Здоров'я та догляд",
      items: [
        {
          q: "Чи проходять ваші коти тести здоров'я?",
          a: "Так. Усі коти-виробники протестовані на PRA, дефіцит PK та інші породоспецифічні генетичні захворювання. Ми ніколи не практикуємо інбридинг. Результати тестів доступні за запитом.",
        },
        {
          q: 'У якому віці можна забрати кошеня?',
          a: "Кошенята від'їжджають у 3 місяці або старше, повністю вакциновані (включаючи сказ), чіповані та з ветеринарним паспортом. Ми ніколи не віддаємо кошенят раніше — цей період критичний для соціалізації та розвитку імунної системи.",
        },
        {
          q: 'Чим годувати орієнтального або сіамського кота?',
          a: "Ми надаємо детальні рекомендації з харчування з кожним кошеням, включаючи конкретний корм, яким вони харчувалися. Рекомендуємо преміум сухий та вологий корм відповідно до віку. Поступовий перехід важливий — різка зміна корму може спричинити проблеми з травленням.",
        },
        {
          q: 'Чи надаєте ви підтримку після купівлі?',
          a: "Завжди. Ельвіра залишається на зв'язку з кожною родиною для порад щодо адаптації, харчування та поведінки — будь-коли. Багато родин спілкуються з нами роками, діляться фото та важливими моментами.",
        },
      ],
    },
    {
      title: 'Про наш розплідник',
      items: [
        {
          q: 'Чи є Floriente зареєстрованим розплідником?',
          a: 'Так. Floriente офіційно зареєстрований у World Cat Federation (WCF), номер реєстрації 50188-2025. Наші коти-виробники мають титули Grand Inter-Champion (GIC). Ельвіра — сертифікований заводчик-фелінолог.',
        },
        {
          q: 'Де ви знаходитесь?',
          a: 'Ми знаходимося в Київській області, Україна. Наші коти живуть з нами вдома — не в клітках і не в окремих приміщеннях. Точна адреса повідомляється після бронювання.',
        },
        {
          q: 'Скільки виводків у вас на рік?',
          a: 'Ми зосереджуємося на якості, а не на кількості, і маємо лише кілька виводків на рік. Кожне кошеня отримує індивідуальну увагу, щоденне спілкування та належну соціалізацію в сімейному середовищі.',
        },
        {
          q: 'Чи можна відвідати розплідник перед купівлею?',
          a: "Ми пропонуємо відеодзвінки, під час яких ви можете побачити наш дім, познайомитися з котами та поставити будь-які запитання. Для міжнародних покупців це найпрактичніший варіант. Особисті візити можна організувати після бронювання.",
        },
      ],
    },
  ],
};

const categories = content[lang];

// Build FAQ schema for SEO
const allFaqs = categories.flatMap(cat => cat.items);
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': allFaqs.map(faq => ({
    '@type': 'Question',
    'name': faq.q,
    'acceptedAnswer': {
      '@type': 'Answer',
      'text': faq.a,
    },
  })),
};
---

<section class="py-16 md:py-24 px-4 sm:px-6">
  <div class="max-w-4xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16">
      <h1 class="font-serif text-3xl md:text-5xl text-dark mb-6">
        {lang === 'en' ? 'Frequently Asked Questions' : 'Часті запитання'}
      </h1>
      <p class="text-dark-soft text-lg leading-relaxed max-w-2xl mx-auto">
        {lang === 'en'
          ? 'Everything you need to know about Oriental and Siamese kittens at Floriente Cattery.'
          : 'Все, що потрібно знати про орієнтальних та сіамських кошенят у розпліднику Floriente.'}
      </p>
    </div>

    <!-- FAQ Categories -->
    <div class="space-y-12">
      {categories.map((category) => (
        <div class="scroll-fade">
          <h2 class="text-sm font-semibold uppercase tracking-wider text-gold mb-6">{category.title}</h2>
          <div class="space-y-4">
            {category.items.map((faq) => (
              <details class="group bg-warm-white border border-gray-light rounded-lg">
                <summary class="flex items-center justify-between cursor-pointer p-6 text-dark font-medium leading-relaxed list-none">
                  <span class="pr-4">{faq.q}</span>
                  <svg class="w-5 h-5 flex-shrink-0 text-gold transition-transform duration-200 group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 5v14M5 12h14" />
                  </svg>
                </summary>
                <div class="px-6 pb-6 pt-0 text-dark-soft text-sm leading-relaxed">
                  {faq.a}
                </div>
              </details>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-16 scroll-fade">
      <p class="text-dark-soft mb-6">
        {lang === 'en'
          ? "Didn't find your answer? We'd love to hear from you."
          : 'Не знайшли відповідь? Ми будемо раді допомогти.'}
      </p>
      <a
        href={getLocalizedPath('/contact/', lang)}
        class="inline-flex items-center gap-2 px-8 py-3.5 bg-gold text-warm-white rounded-sm text-sm tracking-wider uppercase hover:bg-gold-dark transition-colors"
      >
        {t(lang, 'nav.contact')}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>

<!-- FAQ Schema for SEO -->
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
