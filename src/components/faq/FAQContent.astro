---
import { t, getLocalizedPath } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
import { getCollection } from 'astro:content';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const faqEntries = await getCollection('faq', ({ data }) => data.lang === lang);
const fallbackEntries = faqEntries.length > 0 ? faqEntries : await getCollection('faq', ({ data }) => data.lang === 'en');
const categories = fallbackEntries[0].data.categories;

const allFaqs = categories.flatMap(cat => cat.items);
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': allFaqs.map(faq => ({
    '@type': 'Question',
    'name': faq.q,
    'acceptedAnswer': {
      '@type': 'Answer',
      'text': faq.a,
    },
  })),
};
---

<section class="py-16 md:py-24 px-4 sm:px-6">
  <div class="max-w-4xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16">
      <h1 class="font-serif text-3xl md:text-5xl text-dark mb-6">
        {t(lang, 'faq.heroTitle')}
      </h1>
      <p class="text-dark-soft text-lg leading-relaxed max-w-2xl mx-auto">
        {t(lang, 'faq.heroText')}
      </p>
    </div>

    <!-- FAQ Categories -->
    <div class="space-y-12">
      {categories.map((category) => (
        <div class="scroll-fade">
          <h2 class="text-sm font-semibold uppercase tracking-wider text-gold mb-6">{category.title}</h2>
          <div class="space-y-4">
            {category.items.map((faq) => (
              <details class="group bg-warm-white border border-gray-light rounded-lg">
                <summary class="flex items-center justify-between cursor-pointer p-6 text-dark font-medium leading-relaxed list-none">
                  <span class="pr-4">{faq.q}</span>
                  <svg class="w-5 h-5 flex-shrink-0 text-gold transition-transform duration-200 group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 5v14M5 12h14" />
                  </svg>
                </summary>
                <div class="px-6 pb-6 pt-0 text-dark-soft text-sm leading-relaxed">
                  {faq.a}
                </div>
              </details>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-16 scroll-fade">
      <p class="text-dark-soft mb-6">
        {t(lang, 'faq.ctaText')}
      </p>
      <a
        href={getLocalizedPath('/contact/', lang)}
        class="inline-flex items-center gap-2 px-8 py-3.5 bg-gold text-warm-white rounded-sm text-sm tracking-wider uppercase hover:bg-gold-dark transition-colors"
      >
        {t(lang, 'nav.contact')}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>

<!-- FAQ Schema for SEO -->
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
