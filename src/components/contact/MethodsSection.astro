---
import { t } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const contactMethods = [
  {
    labelKey: 'whatsappLabel',
    descKey: 'whatsappDesc',
    ctaKey: 'whatsappCta',
    href: 'https://wa.me/380931884422',
    icon: `<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>`,
    iconFill: true,
    accent: true,
  },
  {
    labelKey: 'instagramDmLabel',
    descKey: 'instagramDmDesc',
    ctaKey: 'instagramDmCta',
    href: 'https://ig.me/m/floriente_orientals_cattery',
    icon: `<rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>`,
    iconFill: false,
    accent: false,
  },
  {
    labelKey: 'emailLabel',
    descKey: 'emailDesc',
    ctaKey: null,
    href: 'mailto:info@florientecattery.com',
    ctaText: 'info@florientecattery.com',
    icon: `<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>`,
    iconFill: false,
    accent: false,
  },
];

const followChannels = [
  {
    labelKey: 'instagramLabel',
    descKey: 'instagramDesc',
    ctaKey: 'instagramCta',
    href: 'https://www.instagram.com/floriente_orientals_cattery',
    icon: `<rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>`,
    iconFill: false,
  },
  {
    labelKey: 'tiktokLabel',
    descKey: 'tiktokDesc',
    ctaKey: 'tiktokCta',
    href: 'https://www.tiktok.com/@floriente_cattery',
    icon: `<path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/>`,
    iconFill: false,
  },
];

const contactTitle = lang === 'en' ? 'Contact Us' : 'Зв\'яжіться з нами';
const followTitle = lang === 'en' ? 'Follow Us' : 'Слідкуйте за нами';
---

<section class="py-16 md:py-24 px-4 sm:px-6 bg-gray-light/20">
  <div class="max-w-5xl mx-auto">

    {/* Contact Us block */}
    <h2 class="text-center mb-4">{contactTitle}</h2>
    <p class="text-center text-gray-medium mb-12 text-sm">
      {lang === 'en'
        ? 'Reach out through any of these channels — we typically reply within a few hours'
        : 'Напишіть нам будь-яким зручним способом — зазвичай відповідаємо протягом кількох годин'}
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16 md:mb-24">
      {contactMethods.map((m) => (
        <a
          href={m.href}
          target={m.href.startsWith('mailto') ? undefined : '_blank'}
          rel={m.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
          class:list={[
            'group block p-8 transition-colors border',
            m.accent
              ? 'bg-gold/5 border-gold/20 hover:bg-gold/10'
              : 'bg-warm-white border-gray-light hover:border-gold/30',
          ]}
        >
          <div class="flex items-start gap-5">
            <div class:list={[
              'flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center',
              m.accent ? 'bg-gold/15' : 'bg-gold/10',
            ]}>
              {m.iconFill ? (
                <svg class="w-6 h-6 text-gold" viewBox="0 0 24 24" fill="currentColor" set:html={m.icon} />
              ) : (
                <svg class="w-6 h-6 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={m.icon} />
              )}
            </div>
            <div class="flex-1">
              <h3 class="text-lg font-serif mb-1">{t(lang, `contact.${m.labelKey}`)}</h3>
              <p class="text-dark-soft text-sm leading-relaxed mb-3">{t(lang, `contact.${m.descKey}`)}</p>
              <span class="inline-flex items-center gap-1 text-sm text-gold group-hover:text-gold-dark transition-colors">
                {m.ctaKey ? t(lang, `contact.${m.ctaKey}`) : m.ctaText}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M12 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>

    {/* Follow Us block */}
    <h2 class="text-center mb-4">{followTitle}</h2>
    <p class="text-center text-gray-medium mb-12 text-sm">
      {lang === 'en'
        ? 'Stay updated with our daily life, new litters, and behind-the-scenes moments'
        : 'Слідкуйте за нашим щоденним життям, новими пометами та моментами за лаштунками'}
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-2xl mx-auto">
      {followChannels.map((m) => (
        <a
          href={m.href}
          target="_blank"
          rel="noopener noreferrer"
          class="group block bg-warm-white border border-gray-light hover:border-gold/30 p-8 transition-colors"
        >
          <div class="flex items-start gap-5">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-gold/10 flex items-center justify-center">
              <svg class="w-6 h-6 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={m.icon} />
            </div>
            <div class="flex-1">
              <h3 class="text-lg font-serif mb-1">{t(lang, `contact.${m.labelKey}`)}</h3>
              <p class="text-dark-soft text-sm leading-relaxed mb-3">{t(lang, `contact.${m.descKey}`)}</p>
              <span class="inline-flex items-center gap-1 text-sm text-gold group-hover:text-gold-dark transition-colors">
                {t(lang, `contact.${m.ctaKey}`)}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M12 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>
