---
interface GalleryPhoto {
  src: string;
  label?: string;
}

interface Props {
  photos: GalleryPhoto[];
  catName: string;
  galleryId?: string;
}

const { photos, catName, galleryId = catName.toLowerCase().replace(/\s/g, '-') } = Astro.props;
---

<div class="cat-gallery">
  <div class="flex gap-3 overflow-x-auto pb-3 snap-x snap-mandatory scrollbar-thin">
    {photos.map((photo, i) => (
      <div
        class="flex-shrink-0 w-48 md:w-64 lg:w-72 snap-start group relative cursor-pointer"
        data-lightbox-gallery={`cat-${galleryId}`}
      >
        <div class="aspect-[3/4] overflow-hidden bg-gray-light/20">
          <img
            src={photo.src}
            alt={`${catName} — ${photo.label || `photo ${i + 2}`}`}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            loading="lazy"
          />
        </div>
        {photo.label && (
          <p class="text-[10px] text-gray-medium mt-1.5 text-center uppercase tracking-wider">{photo.label}</p>
        )}
      </div>
    ))}
  </div>
</div>

<style>
  .scrollbar-thin {
    scrollbar-width: thin;
    scrollbar-color: rgba(181, 152, 105, 0.3) transparent;
  }
  .scrollbar-thin::-webkit-scrollbar {
    height: 4px;
  }
  .scrollbar-thin::-webkit-scrollbar-track {
    background: transparent;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb {
    background-color: rgba(181, 152, 105, 0.3);
    border-radius: 2px;
  }
</style>
