---
interface GalleryPhoto {
  src: string;
  label?: string;
}

interface Props {
  photos: GalleryPhoto[];
  catName: string;
}

const { photos, catName } = Astro.props;
---

<div class="cat-gallery">
  <div class="flex gap-3 overflow-x-auto pb-3 snap-x snap-mandatory scrollbar-thin">
    {photos.map((photo, i) => (
      <div class="flex-shrink-0 w-48 md:w-64 lg:w-72 snap-start group relative cursor-pointer" data-lightbox-trigger>
        <div class="aspect-[3/4] overflow-hidden bg-gray-light/20">
          <img
            src={photo.src}
            alt={`${catName} — ${photo.label || `photo ${i + 2}`}`}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            loading="lazy"
          />
        </div>
        {photo.label && (
          <p class="text-[10px] text-gray-medium mt-1.5 text-center uppercase tracking-wider">{photo.label}</p>
        )}
      </div>
    ))}
  </div>
</div>

<!-- Lightbox overlay -->
<div class="cat-lightbox hidden fixed inset-0 z-50 bg-dark/90 flex items-center justify-center p-4 cursor-pointer">
  <button class="absolute top-4 right-4 text-warm-white text-3xl hover:text-gold transition-colors z-10" aria-label="Close">&times;</button>
  <img src="" alt="" class="max-w-[90vw] max-h-[90vh] object-contain" />
</div>

<style>
  .scrollbar-thin {
    scrollbar-width: thin;
    scrollbar-color: rgba(181, 152, 105, 0.3) transparent;
  }
  .scrollbar-thin::-webkit-scrollbar {
    height: 4px;
  }
  .scrollbar-thin::-webkit-scrollbar-track {
    background: transparent;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb {
    background-color: rgba(181, 152, 105, 0.3);
    border-radius: 2px;
  }
</style>

<script>
  document.querySelectorAll('.cat-gallery').forEach((gallery) => {
    const lightbox = gallery.nextElementSibling as HTMLElement;
    if (!lightbox?.classList.contains('cat-lightbox')) return;

    const lightboxImg = lightbox.querySelector('img') as HTMLImageElement;

    gallery.querySelectorAll('[data-lightbox-trigger]').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const img = trigger.querySelector('img') as HTMLImageElement;
        if (img) {
          lightboxImg.src = img.src;
          lightboxImg.alt = img.alt;
          lightbox.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
        }
      });
    });

    lightbox.addEventListener('click', () => {
      lightbox.classList.add('hidden');
      document.body.style.overflow = '';
    });
  });
</script>
