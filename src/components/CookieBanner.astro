---
import { t, getLocalizedPath } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const text = {
  en: 'This website uses essential cookies for basic functionality. By continuing to browse, you accept our',
  uk: 'Цей вебсайт використовує необхідні cookies для базової функціональності. Продовжуючи перегляд, ви приймаєте нашу',
};

const linkText = {
  en: 'Cookie Policy',
  uk: 'Політику cookies',
};

const btnText = {
  en: 'Accept',
  uk: 'Прийняти',
};
---

<div
  id="cookie-banner"
  class="fixed bottom-0 left-0 right-0 z-[90] bg-dark text-warm-white/80 px-4 py-4 hidden"
>
  <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-sm leading-relaxed text-center sm:text-left">
      {text[lang]}{' '}
      <a
        href={getLocalizedPath('/legal/#cookies', lang)}
        class="text-gold hover:text-gold-light underline"
      >
        {linkText[lang]}
      </a>.
    </p>
    <button
      id="cookie-accept"
      class="flex-shrink-0 px-6 py-2 bg-gold text-warm-white text-sm font-medium rounded-sm hover:bg-gold-dark transition-colors"
    >
      {btnText[lang]}
    </button>
  </div>
</div>

<script>
  const banner = document.getElementById('cookie-banner');
  const acceptBtn = document.getElementById('cookie-accept');

  if (!localStorage.getItem('cookies-accepted')) {
    banner?.classList.remove('hidden');
  }

  acceptBtn?.addEventListener('click', () => {
    localStorage.setItem('cookies-accepted', 'true');
    banner?.classList.add('hidden');
  });
</script>
