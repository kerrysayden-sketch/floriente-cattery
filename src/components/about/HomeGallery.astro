---
import { t } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const photos = [
  { src: '/images/cats/home-gallery-1.jpg', alt: 'Two oriental kittens cuddled together on a colorful armchair', span: true },
  { src: '/images/cats/home-gallery-2.jpg', alt: 'Sebastian and kitten in sunlit living room' },
  { src: '/images/cats/home-gallery-3.jpg', alt: 'Oriental kitten exploring plants at home' },
  { src: '/images/cats/home-gallery-4.jpg', alt: 'Oriental cat relaxing in a cozy bed by the window' },
  { src: '/images/cats/home-gallery-5.jpg', alt: 'Siamese kitten sitting on a playful blanket with toys' },
  { src: '/images/cats/home-gallery-6.jpg', alt: 'Three Siamese kittens cuddled together on a patchwork armchair' },
];
---

<section class="py-16 md:py-24 px-4 sm:px-6">
  <div class="max-w-6xl mx-auto text-center">
    <h2 class="mb-2">{t(lang, 'about.homeTitle')}</h2>
    <p class="text-gray-medium mb-12">{t(lang, 'about.homeSubtitle')}</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
      {photos.map((photo, i) => (
        <div class:list={[
          'rounded-lg overflow-hidden group',
          i === 0 ? 'col-span-2 md:col-span-2 md:row-span-2 aspect-[4/3] md:aspect-square' : 'aspect-square',
        ]} data-lightbox-gallery="about-home">
          <img
            src={photo.src}
            alt={photo.alt}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>
