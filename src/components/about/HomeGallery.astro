---
import { t } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="py-16 md:py-24 px-4 sm:px-6">
  <div class="max-w-6xl mx-auto text-center">
    <h2 class="mb-2">{t(lang, 'about.homeTitle')}</h2>
    <p class="text-gray-medium mb-12">{t(lang, 'about.homeSubtitle')}</p>

    <!-- TODO: Replace with real cat photos showing home environment -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {[1, 2, 3, 4, 5, 6].map((i) => (
        <div class:list={[
          'rounded-lg bg-gray-light/50 flex items-center justify-center overflow-hidden',
          i <= 2 ? 'aspect-[4/3]' : 'aspect-square',
          i === 1 ? 'md:col-span-2 md:row-span-2 md:aspect-square' : '',
        ]}>
          <svg class="w-12 h-12 text-gold/20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
      ))}
    </div>
  </div>
</section>
