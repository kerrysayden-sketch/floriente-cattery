---
import { t } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const photos = [
  { src: '/images/cats/home-gallery-1.jpg', alt: 'Oriental cat at home', span: true },
  { src: '/images/cats/home-gallery-2.jpg', alt: 'Oriental cat portrait' },
  { src: '/images/cats/home-gallery-3.jpg', alt: 'Oriental cat looking at camera' },
  { src: '/images/cats/home-gallery-4.jpg', alt: 'Oriental cat in motion' },
  { src: '/images/cats/home-gallery-5.jpg', alt: 'Oriental cat resting' },
  { src: '/images/cats/home-gallery-6.jpg', alt: 'Oriental cat relaxing' },
];
---

<section class="py-16 md:py-24 px-4 sm:px-6">
  <div class="max-w-6xl mx-auto text-center">
    <h2 class="mb-2">{t(lang, 'about.homeTitle')}</h2>
    <p class="text-gray-medium mb-12">{t(lang, 'about.homeSubtitle')}</p>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {photos.map((photo, i) => (
        <div class:list={[
          'rounded-lg overflow-hidden',
          i <= 1 ? 'aspect-[4/3]' : 'aspect-square',
          photo.span ? 'md:col-span-2 md:row-span-2 md:aspect-square' : '',
        ]}>
          <img
            src={photo.src}
            alt={photo.alt}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>
