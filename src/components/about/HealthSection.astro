---
import { t } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="py-16 md:py-24 px-4 sm:px-6 bg-gray-light/20">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-center mb-6">{t(lang, 'about.healthTitle')}</h2>
    <p class="text-center text-dark-soft leading-relaxed mb-8 max-w-2xl mx-auto">
      {t(lang, 'about.healthText')}
    </p>

    <div class="bg-warm-white border border-gray-light rounded-lg p-8 md:p-10">
      <p class="text-dark-soft leading-relaxed mb-6">
        {t(lang, 'about.healthTests')}
      </p>

      <h3 class="text-lg font-serif mb-4">{t(lang, 'about.healthLabsTitle')}</h3>
      <div class="flex flex-wrap gap-4">
        <a
          href="https://www.laboklin.de"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 border border-gray-light rounded text-sm text-dark-soft hover:border-gold hover:text-gold transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
          </svg>
          Laboklin
        </a>
        <a
          href="https://www.antagene.com"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 border border-gray-light rounded text-sm text-dark-soft hover:border-gold hover:text-gold transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
          </svg>
          Antagene
        </a>
      </div>
    </div>
  </div>
</section>
