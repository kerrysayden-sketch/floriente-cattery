---
import { t } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const principles = [
  { icon: 'M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z', titleKey: 'philosophyHealth', descKey: 'philosophyHealthDesc' },
  { icon: 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z M9 22V12h6v10', titleKey: 'philosophyHome', descKey: 'philosophyHomeDesc' },
  { icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z', titleKey: 'philosophyQuality', descKey: 'philosophyQualityDesc' },
  { icon: 'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2 M9 7a4 4 0 1 0 0-8 4 4 0 0 0 0 8z M23 21v-2a4 4 0 0 0-3-3.87 M16 3.13a4 4 0 0 1 0 7.75', titleKey: 'philosophySupport', descKey: 'philosophySupportDesc' },
];
---

<section class="py-16 md:py-24 px-4 sm:px-6 bg-gray-light/20">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-center mb-16">{t(lang, 'about.philosophyTitle')}</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
      {principles.map((p) => (
        <div class="flex gap-5">
          <div class="flex-shrink-0 w-12 h-12 rounded-full bg-gold/10 flex items-center justify-center">
            <svg class="w-6 h-6 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d={p.icon} />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-serif mb-2">{t(lang, `about.${p.titleKey}`)}</h3>
            <p class="text-dark-soft text-sm leading-relaxed">{t(lang, `about.${p.descKey}`)}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
