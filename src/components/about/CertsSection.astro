---
import { t } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const landscapeCerts = [
  { src: '/images/certs/wcf-registration.jpg', alt: 'WCF Cattery Registration - Floriente #50188-2025' },
  { src: '/images/certs/wcf-seminar.jpg', alt: 'WCF Exhibitor-Seminar - June 2024, Ternopil' },
];

const sebastianCerts = [
  { src: '/images/certs/ch-sebastian.jpg', alt: 'Champion - Sebastian Ole Lukhoye' },
  { src: '/images/certs/ich-sebastian.jpg', alt: 'Inter-Champion - Sebastian Ole Lukhoye' },
  { src: '/images/certs/gic-sebastian.jpg', alt: 'Grand Inter-Champion - Sebastian Ole Lukhoye' },
];

const simonaCerts = [
  { src: '/images/certs/ch-simona.jpg', alt: 'Champion - Belly Dance Simona' },
  { src: '/images/certs/ich-simona.jpg', alt: 'Inter-Champion - Belly Dance Simona' },
  { src: '/images/certs/gic-simona.jpg', alt: 'Grand Inter-Champion - Belly Dance Simona' },
];

const educationCerts = [
  { src: '/images/certs/felinologist.jpg', alt: 'Felinological Seminar - Breeder-Felinologist Certificate' },
  { src: '/images/certs/breeder-felinologist-2025.jpg', alt: 'Breeder-Felinologist Certificate - June 2025, Ternopil' },
];
---

<section class="py-16 md:py-24 px-4 sm:px-6">
  <div class="max-w-5xl mx-auto text-center">
    <h2 class="mb-2">{t(lang, 'about.certsTitle')}</h2>
    <p class="text-gray-medium mb-16">{t(lang, 'about.certsSubtitle')}</p>

    <!-- Row 1: Cattery & Education - 2 landscape certificates side by side -->
    <h3 class="text-sm font-semibold uppercase tracking-wider text-gold mb-6">
      {t(lang, 'about.certsCattery')} & {t(lang, 'about.certsEducation')}
    </h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
      {landscapeCerts.map((cert) => (
        <div class="cert-card group cursor-pointer">
          <div class="aspect-[4/3] rounded-lg overflow-hidden border border-gray-light shadow-sm hover:shadow-md transition-shadow relative">
            <img
              src={cert.src}
              alt={cert.alt}
              class="w-full h-full object-contain bg-gray-light/20 grayscale group-hover:grayscale-0 transition-all duration-500"
              loading="lazy"
            />
            <div class="cert-watermark">Floriente Cattery</div>
            <div class="cert-overlay"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Row 2: Sebastian - Champion → Inter-Champion → Grand Inter-Champion -->
    <h3 class="text-sm font-semibold uppercase tracking-wider text-gold mb-6">
      Sebastian Ole Lukhoye
    </h3>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 md:gap-6 mb-10">
      {sebastianCerts.map((cert) => (
        <div class="cert-card group cursor-pointer">
          <div class="aspect-[3/4] rounded-lg overflow-hidden border border-gray-light shadow-sm hover:shadow-md transition-shadow relative">
            <img
              src={cert.src}
              alt={cert.alt}
              class="w-full h-full object-contain bg-gray-light/20 grayscale group-hover:grayscale-0 transition-all duration-500"
              loading="lazy"
            />
            <div class="cert-watermark">Floriente Cattery</div>
            <div class="cert-overlay"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Row 3: Simona - Champion → Inter-Champion → Grand Inter-Champion -->
    <h3 class="text-sm font-semibold uppercase tracking-wider text-gold mb-6">
      Belly Dance Simona
    </h3>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 md:gap-6 mb-10">
      {simonaCerts.map((cert) => (
        <div class="cert-card group cursor-pointer">
          <div class="aspect-[3/4] rounded-lg overflow-hidden border border-gray-light shadow-sm hover:shadow-md transition-shadow relative">
            <img
              src={cert.src}
              alt={cert.alt}
              class="w-full h-full object-contain bg-gray-light/20 grayscale group-hover:grayscale-0 transition-all duration-500"
              loading="lazy"
            />
            <div class="cert-watermark">Floriente Cattery</div>
            <div class="cert-overlay"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Row 4: Education -->
    <h3 class="text-sm font-semibold uppercase tracking-wider text-gold mb-6">
      {t(lang, 'about.certsEducation')}
    </h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 md:gap-6">
      {educationCerts.map((cert) => (
        <div class="cert-card group cursor-pointer">
          <div class="aspect-[3/4] rounded-lg overflow-hidden border border-gray-light shadow-sm hover:shadow-md transition-shadow relative">
            <img
              src={cert.src}
              alt={cert.alt}
              class="w-full h-full object-contain bg-gray-light/20 grayscale group-hover:grayscale-0 transition-all duration-500"
              loading="lazy"
            />
            <div class="cert-watermark">Floriente Cattery</div>
            <div class="cert-overlay"></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Watermark + Touch device support -->
<style>
  .cert-watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(-30deg);
    font-family: var(--font-serif);
    font-size: clamp(1.1rem, 4vw, 2rem);
    font-weight: 700;
    color: rgba(139, 115, 85, 0.35);
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    z-index: 2;
    text-shadow: 0 0 8px rgba(255, 255, 255, 0.5);
  }
  .cert-card img.touched {
    filter: grayscale(0) !important;
  }
  /* Transparent overlay prevents "Save Image As" */
  .cert-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 3;
    background: transparent;
    cursor: default;
  }
  /* Copy protection */
  .cert-card img {
    -webkit-user-drag: none;
    -khtml-user-drag: none;
    -moz-user-drag: none;
    -o-user-drag: none;
    user-drag: none;
    -webkit-touch-callout: none;
  }
  .cert-card {
    -webkit-user-select: none;
    user-select: none;
  }
</style>

<script>
  // On touch devices: tap to show color, revert after 3 seconds.
  // Listener goes on .cert-card (not img) because .cert-overlay sits above img at z-index:3
  // and absorbs all touch events before they reach the image.
  if ('ontouchstart' in window || navigator.maxTouchPoints > 0) {
    document.querySelectorAll('.cert-card').forEach((card) => {
      card.addEventListener('touchstart', () => {
        const img = card.querySelector('img');
        if (!img) return;
        img.classList.add('touched');
        setTimeout(() => img.classList.remove('touched'), 3000);
      }, { passive: true });
    });
  }

  // Disable right-click on certificate images
  document.querySelectorAll('.cert-card img').forEach((img) => {
    img.addEventListener('contextmenu', (e) => e.preventDefault());
  });

  // Disable long-press save on mobile (overlay already covers, belt + suspenders)
  document.querySelectorAll('.cert-card').forEach((card) => {
    card.addEventListener('contextmenu', (e) => e.preventDefault());
  });
</script>
