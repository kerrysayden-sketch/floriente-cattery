---
import { t } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const landscapeCerts = [
  { src: '/images/certs/wcf-registration.webp', alt: 'WCF Cattery Registration - Floriente #50188-2025' },
  { src: '/images/certs/wcf-seminar.webp', alt: 'WCF Exhibitor-Seminar - June 2024, Ternopil' },
];

const sebastianCerts = [
  { src: '/images/certs/ch-sebastian.webp', alt: 'Champion - Sebastian Ole Lukhoye' },
  { src: '/images/certs/ich-sebastian.webp', alt: 'Inter-Champion - Sebastian Ole Lukhoye' },
  { src: '/images/certs/gic-sebastian.webp', alt: 'Grand Inter-Champion - Sebastian Ole Lukhoye' },
];

const simonaCerts = [
  { src: '/images/certs/ch-simona.webp', alt: 'Champion - Belly Dance Simona' },
  { src: '/images/certs/ich-simona.webp', alt: 'Inter-Champion - Belly Dance Simona' },
  { src: '/images/certs/gic-simona.webp', alt: 'Grand Inter-Champion - Belly Dance Simona' },
];

const educationCerts = [
  { src: '/images/certs/felinologist.webp', alt: 'Felinological Seminar - Breeder-Felinologist Certificate' },
  { src: '/images/certs/breeder-felinologist-2025.webp', alt: 'Breeder-Felinologist Certificate - June 2025, Ternopil' },
];

const geneticCerts = [
  { src: '/images/certs/genetic-sebastian.webp', alt: 'Genetic test (PKdef N/N, PRA-rdAc N/N) - Sebastian Ole Lukhoye, SOVA GenLab' },
  { src: '/images/certs/genetic-simona.webp', alt: 'Genetic test (PKdef N/N, PRA-rdAc N/N) - Belly Dance Simona, SOVA GenLab' },
  { src: '/images/certs/genetic-heldig.webp', alt: 'Genetic test (PKdef N/N, PRA-rdAc N/N) - Heldig, SOVA GenLab' },
];
---

<section class="py-16 md:py-24 px-4 sm:px-6">
  <div class="max-w-5xl mx-auto text-center">
    <h2 class="mb-2">{t(lang, 'about.certsTitle')}</h2>
    <p class="text-gray-medium mb-16">{t(lang, 'about.certsSubtitle')}</p>

    <!-- Row 1: Cattery & Education - 2 landscape certificates side by side -->
    <h3 class="text-sm font-semibold uppercase tracking-wider text-gold mb-6">
      {t(lang, 'about.certsCattery')} & {t(lang, 'about.certsEducation')}
    </h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
      {landscapeCerts.map((cert) => (
        <div class="cert-card group cursor-pointer">
          <div class="aspect-[4/3] rounded-lg overflow-hidden border border-gray-light shadow-sm hover:shadow-md transition-shadow relative">
            <img
              src={cert.src}
              alt={cert.alt}
              class="w-full h-full object-contain bg-gray-light/20 grayscale group-hover:grayscale-0 transition-all duration-500"
              loading="lazy"
            />
            <div class="cert-watermark">Floriente Cattery</div>
            <div class="cert-overlay"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Row 2: Sebastian - Champion → Inter-Champion → Grand Inter-Champion -->
    <h3 class="text-sm font-semibold uppercase tracking-wider text-gold mb-6">
      Sebastian Ole Lukhoye
    </h3>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 md:gap-6 mb-10">
      {sebastianCerts.map((cert) => (
        <div class="cert-card group cursor-pointer">
          <div class="aspect-[3/4] rounded-lg overflow-hidden border border-gray-light shadow-sm hover:shadow-md transition-shadow relative">
            <img
              src={cert.src}
              alt={cert.alt}
              class="w-full h-full object-contain bg-gray-light/20 grayscale group-hover:grayscale-0 transition-all duration-500"
              loading="lazy"
            />
            <div class="cert-watermark">Floriente Cattery</div>
            <div class="cert-overlay"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Row 3: Simona - Champion → Inter-Champion → Grand Inter-Champion -->
    <h3 class="text-sm font-semibold uppercase tracking-wider text-gold mb-6">
      Belly Dance Simona
    </h3>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 md:gap-6 mb-10">
      {simonaCerts.map((cert) => (
        <div class="cert-card group cursor-pointer">
          <div class="aspect-[3/4] rounded-lg overflow-hidden border border-gray-light shadow-sm hover:shadow-md transition-shadow relative">
            <img
              src={cert.src}
              alt={cert.alt}
              class="w-full h-full object-contain bg-gray-light/20 grayscale group-hover:grayscale-0 transition-all duration-500"
              loading="lazy"
            />
            <div class="cert-watermark">Floriente Cattery</div>
            <div class="cert-overlay"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Row 4: Education -->
    <h3 class="text-sm font-semibold uppercase tracking-wider text-gold mb-6">
      {t(lang, 'about.certsEducation')}
    </h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 md:gap-6">
      {educationCerts.map((cert) => (
        <div class="cert-card group cursor-pointer">
          <div class="aspect-[3/4] rounded-lg overflow-hidden border border-gray-light shadow-sm hover:shadow-md transition-shadow relative">
            <img
              src={cert.src}
              alt={cert.alt}
              class="w-full h-full object-contain bg-gray-light/20 grayscale group-hover:grayscale-0 transition-all duration-500"
              loading="lazy"
            />
            <div class="cert-watermark">Floriente Cattery</div>
            <div class="cert-overlay"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Row 5: Health & Genetic Testing (readable, no grayscale) -->
    <h3 id="genetic-tests" class="text-sm font-semibold uppercase tracking-wider text-gold mb-6 mt-10 scroll-mt-28">
      {t(lang, 'about.certsGenetic')}
    </h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {geneticCerts.map((cert) => (
        <div class="cert-card group cursor-pointer">
          <div class="aspect-[100/141] rounded-lg overflow-hidden border border-gray-light shadow-sm hover:shadow-md transition-shadow relative">
            <img
              src={cert.src}
              alt={cert.alt}
              class="w-full h-full object-contain bg-gray-light/20 grayscale group-hover:grayscale-0 transition-all duration-500"
              loading="lazy"
            />
            <div class="cert-watermark">Floriente Cattery</div>
            <div class="cert-overlay"></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Certificate lightbox (click any cert to read it enlarged) -->
<div id="cert-lightbox" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/80 p-4" role="dialog" aria-modal="true" aria-label="Certificate">
  <button id="cert-lightbox-close" aria-label="Close" class="absolute top-3 right-5 text-white/70 hover:text-white text-4xl leading-none z-10">&times;</button>
  <div class="relative max-w-3xl w-full flex items-center justify-center">
    <img id="cert-lightbox-img" src="" alt="" class="max-w-full max-h-[88vh] object-contain rounded shadow-2xl" />
    <div class="cert-watermark">Floriente Cattery</div>
    <div class="cert-overlay"></div>
  </div>
</div>

<!-- Watermark + Touch device support -->
<style>
  .cert-watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(-30deg);
    font-family: var(--font-serif);
    font-size: clamp(1.1rem, 4vw, 2rem);
    font-weight: 700;
    color: rgba(139, 115, 85, 0.35);
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    z-index: 2;
    text-shadow: 0 0 8px rgba(255, 255, 255, 0.5);
  }
  .cert-card img.touched {
    filter: grayscale(0) !important;
  }
  /* Transparent overlay prevents "Save Image As" */
  .cert-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 3;
    background: transparent;
    cursor: default;
  }
  /* Copy protection */
  .cert-card img {
    -webkit-user-drag: none;
    -khtml-user-drag: none;
    -moz-user-drag: none;
    -o-user-drag: none;
    user-drag: none;
    -webkit-touch-callout: none;
  }
  .cert-card {
    -webkit-user-select: none;
    user-select: none;
  }
</style>

<script>
  // On touch devices: tap to show color, revert after 3 seconds.
  // Listener goes on .cert-card (not img) because .cert-overlay sits above img at z-index:3
  // and absorbs all touch events before they reach the image.
  if ('ontouchstart' in window || navigator.maxTouchPoints > 0) {
    document.querySelectorAll('.cert-card').forEach((card) => {
      card.addEventListener('touchstart', () => {
        const img = card.querySelector('img');
        if (!img) return;
        img.classList.add('touched');
        setTimeout(() => img.classList.remove('touched'), 3000);
      }, { passive: true });
    });
  }

  // Disable right-click on certificate images
  document.querySelectorAll('.cert-card img').forEach((img) => {
    img.addEventListener('contextmenu', (e) => e.preventDefault());
  });

  // Disable long-press save on mobile (overlay already covers, belt + suspenders)
  document.querySelectorAll('.cert-card').forEach((card) => {
    card.addEventListener('contextmenu', (e) => e.preventDefault());
  });

  // Lightbox: click any certificate to read it enlarged (copy-protection preserved)
  const lb = document.getElementById('cert-lightbox');
  const lbImg = document.getElementById('cert-lightbox-img');
  const lbClose = document.getElementById('cert-lightbox-close');
  if (lb && lbImg && lbClose) {
    const open = (src, alt) => {
      lbImg.setAttribute('src', src);
      lbImg.setAttribute('alt', alt || '');
      lb.classList.remove('hidden');
      lb.classList.add('flex');
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      lb.classList.add('hidden');
      lb.classList.remove('flex');
      lbImg.setAttribute('src', '');
      document.body.style.overflow = '';
    };
    document.querySelectorAll('.cert-card').forEach((card) => {
      card.addEventListener('click', () => {
        const img = card.querySelector('img');
        if (img) open(img.getAttribute('src'), img.getAttribute('alt'));
      });
    });
    lbClose.addEventListener('click', close);
    lb.addEventListener('click', (e) => { if (e.target === lb) close(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
    lbImg.addEventListener('contextmenu', (e) => e.preventDefault());
  }
</script>
