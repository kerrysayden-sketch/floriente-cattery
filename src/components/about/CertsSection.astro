---
import { t } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="py-16 md:py-24 px-4 sm:px-6">
  <div class="max-w-6xl mx-auto text-center">
    <h2 class="mb-2">{t(lang, 'about.certsTitle')}</h2>
    <p class="text-gray-medium mb-12">{t(lang, 'about.certsSubtitle')}</p>

    <!-- TODO: Replace with real certificate images -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {['WCF Registration', 'GIC Certificate', 'Seminar Certificate'].map((label) => (
        <div class="aspect-[3/4] rounded-lg bg-gray-light/50 flex items-center justify-center border border-gray-light">
          <div class="text-center">
            <svg class="w-12 h-12 text-gold/30 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            <p class="text-sm text-gray-medium">{label}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
