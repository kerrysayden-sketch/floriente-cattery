---
import { t, getLocalizedPath } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

// Three honest pillars for international buyers. Claims are intentionally modest —
// specifics (which countries, which routes, Pet Passport readiness) are deferred to
// the 1:1 video call because they depend on each kitten's age, vaccine schedule,
// and current export documentation. This avoids overclaiming on the website.
// Keys point at howToBuy.intlPillarNTitle / howToBuy.intlPillarNText in each locale.
// Flat camelCase (no dots inside the leaf key name) so t()'s dot-split resolver works.
const pillars = [
  { k: 'intlPillar1', iconPath: 'M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5z' },
  { k: 'intlPillar2', iconPath: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z' },
  { k: 'intlPillar3', iconPath: 'M4 6h16M4 12h16M4 18h16' },
];
---

<section class="py-16 md:py-24 px-4 sm:px-6 bg-gray-light/15">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-center mb-3">{t(lang, 'howToBuy.intlTitle')}</h2>
    <p class="text-center text-gray-medium mb-12 max-w-2xl mx-auto text-sm md:text-base leading-relaxed">
      {t(lang, 'howToBuy.intlSubtitle')}
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
      {pillars.map((p) => (
        <div class="p-6 bg-warm-white border border-gray-light">
          <div class="w-10 h-10 rounded-full bg-gold/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d={p.iconPath} />
            </svg>
          </div>
          <h3 class="font-serif text-lg mb-2">{t(lang, `howToBuy.${p.k}Title`)}</h3>
          <p class="text-dark-soft text-sm leading-relaxed">{t(lang, `howToBuy.${p.k}Text`)}</p>
        </div>
      ))}
    </div>

    <div class="text-center">
      <p class="text-dark-soft text-sm mb-5 max-w-2xl mx-auto leading-relaxed italic">
        {t(lang, 'howToBuy.intlDisclaimer')}
      </p>
      <a
        href={getLocalizedPath('/contact/', lang)}
        class="inline-block px-8 py-3 border border-gold text-gold font-medium hover:bg-gold hover:text-warm-white transition-colors text-sm uppercase tracking-wider"
      >
        {t(lang, 'howToBuy.intlCta')}
      </a>
    </div>
  </div>
</section>
