---
import { t } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const rows = [
  'Chip', 'Vaccines', 'Neuter', 'Pedigree', 'Genetics', 'Socialization', 'Support',
];
---

<section class="py-16 md:py-24 px-4 sm:px-6">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-center mb-3">{t(lang, 'howToBuy.tcoTitle')}</h2>
    <p class="text-center text-dark-soft mb-12 max-w-2xl mx-auto">{t(lang, 'howToBuy.tcoSubtitle')}</p>

    <div class="overflow-hidden rounded-lg border border-gray-light">
      <!-- Header -->
      <div class="grid grid-cols-3 bg-gold/10">
        <div class="p-4 text-sm font-medium text-dark-soft"></div>
        <div class="p-4 text-sm font-semibold text-gold text-center border-l border-gray-light">
          <svg class="w-5 h-5 mx-auto mb-1 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          {t(lang, 'howToBuy.tcoBreeder')}
        </div>
        <div class="p-4 text-sm font-medium text-dark-soft text-center border-l border-gray-light">
          {t(lang, 'howToBuy.tcoAlternative')}
        </div>
      </div>

      <!-- Rows -->
      {rows.map((key, i) => (
        <div class:list={['grid grid-cols-3', i % 2 === 0 ? 'bg-warm-white' : 'bg-gray-light/10']}>
          <div class="p-4 text-sm font-medium text-dark border-t border-gray-light">
            {t(lang, `howToBuy.tco${key}`)}
          </div>
          <div class="p-4 text-sm text-gold text-center border-t border-l border-gray-light font-medium">
            {t(lang, `howToBuy.tco${key}Yes`)}
          </div>
          <div class="p-4 text-sm text-dark-soft text-center border-t border-l border-gray-light">
            {t(lang, `howToBuy.tco${key}No`)}
          </div>
        </div>
      ))}

      <!-- Savings row -->
      <div class="grid grid-cols-3 bg-gold/5 border-t-2 border-accent-gold/30">
        <div class="p-4 text-sm font-semibold text-dark">
          {t(lang, 'howToBuy.tcoSavings')}
        </div>
        <div class="p-4 text-center border-l border-gray-light" colspan="2">
          <span class="text-gold font-serif text-xl font-semibold">{t(lang, 'howToBuy.tcoSavingsAmount')}</span>
        </div>
        <div class="p-4 border-l border-gray-light"></div>
      </div>
    </div>
  </div>
</section>
