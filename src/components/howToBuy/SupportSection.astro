---
import { t, getLocalizedPath } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const responsibilities = ['resp1', 'resp2', 'resp3', 'resp4'];
---

<section class="py-16 md:py-24 px-4 sm:px-6">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
      <!-- Buyer Responsibilities -->
      <div>
        <h2 class="mb-3">{t(lang, 'howToBuy.responsibilitiesTitle')}</h2>
        <p class="text-dark-soft mb-8">{t(lang, 'howToBuy.responsibilitiesSubtitle')}</p>
        <ul class="space-y-4">
          {responsibilities.map((key) => (
            <li class="flex gap-3 items-start">
              <div class="flex-shrink-0 w-6 h-6 rounded-full bg-gold/10 flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <span class="text-dark-soft text-sm leading-relaxed">{t(lang, `howToBuy.${key}`)}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Post-Sale Support -->
      <div>
        <h2 class="mb-6">{t(lang, 'howToBuy.supportTitle')}</h2>
        <p class="text-dark-soft leading-relaxed mb-8">
          {t(lang, 'howToBuy.supportText')}
        </p>
        <blockquote class="border-l-4 border-gold pl-6 italic font-serif text-lg text-dark-soft leading-relaxed">
          {t(lang, 'howToBuy.supportQuote')}
        </blockquote>
      </div>
    </div>

    <!-- FAQ callout -->
    <div class="mt-16">
      <a
        href={getLocalizedPath('/faq/', lang)}
        class="block max-w-md mx-auto bg-gold/5 border border-gold/20 rounded-lg p-6 text-center hover:bg-gold/10 transition-colors group"
      >
        <svg class="w-8 h-8 mx-auto mb-3 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p class="text-dark font-medium mb-1">
          {lang === 'en' ? 'Have more questions?' : 'Маєте більше запитань?'}
        </p>
        <p class="text-gold text-sm group-hover:text-gold-dark transition-colors">
          {lang === 'en' ? 'See our FAQ →' : 'Дивіться FAQ →'}
        </p>
      </a>
    </div>
  </div>
</section>
