---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLocalizedPath, locales } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Floriente Cattery — Oriental Shorthair & Siamese kittens. Raised at home. Transparent from day one.',
  lang = 'en',
  ogImage = '/images/floriente_dark_navy_transparent.png',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const pathWithoutLang = Astro.url.pathname.replace(/^\/(en|uk)/, '') || '/';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="canonical" href={canonicalURL} />

    <!-- hreflang for i18n SEO -->
    {locales.map((locale) => (
      <link
        rel="alternate"
        hreflang={locale}
        href={new URL(getLocalizedPath(pathWithoutLang, locale), Astro.site)}
      />
    ))}
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(getLocalizedPath(pathWithoutLang, 'en'), Astro.site)}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Google Fonts: Cormorant Garamond + Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@300;400;500;600&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Floriente Cattery" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Floriente Cattery",
      "description": "Boutique cattery specializing in Oriental Shorthair and Siamese cats. WCF registered. Kyiv Region, Ukraine.",
      "url": "https://florientecattery.com",
      "logo": "https://florientecattery.com/images/floriente_dark_navy_transparent.png",
      "image": "https://florientecattery.com/images/cats/sebastian.jpg",
      "telephone": "+380931884422",
      "email": "info@florientecattery.com",
      "address": {
        "@type": "PostalAddress",
        "addressRegion": "Kyiv Region",
        "addressCountry": "UA"
      },
      "sameAs": [
        "https://www.instagram.com/floriente_orientals_cattery",
        "https://www.facebook.com/elvira.naurzalina",
        "https://www.tiktok.com/@floriente_cattery"
      ]
    })} />
  </head>
  <body class="min-h-screen bg-warm-white text-dark flex flex-col">
    <Header lang={lang} />
    <main class="flex-1 pt-20">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
