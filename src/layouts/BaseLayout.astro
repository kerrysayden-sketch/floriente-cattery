---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import GlobalLightbox from '../components/ui/GlobalLightbox.astro';
import { getLocalizedPath, locales, indexableLocales, isNoindexLocale } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
  ogImage?: string;
  /** Override noindex. If omitted, defaults to true for machine-translated locales (PL/DE). */
  noindex?: boolean;
}

const {
  title,
  description = 'Floriente Cattery - Oriental Shorthair & Siamese kittens. Raised at home. Transparent from day one.',
  lang = 'en',
  ogImage = '/images/cats/sebastian-main.webp',
  noindex,
} = Astro.props;

const shouldNoindex = noindex ?? isNoindexLocale(lang);

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const langStrip = new RegExp(`^/(${locales.join('|')})(?=/|$)`);
const pathWithoutLang = Astro.url.pathname.replace(langStrip, '') || '/';
const absoluteOgImage = ogImage.startsWith('http') ? ogImage : new URL(ogImage, Astro.site).toString();

// Cloudflare Web Analytics token — set PUBLIC_CF_ANALYTICS_TOKEN in Netlify env.
// If unset, the beacon is not injected (zero tracking, zero network).
const cfAnalyticsToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {shouldNoindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="canonical" href={canonicalURL} />

    <!-- hreflang for i18n SEO (only indexable locales; PL/DE excluded until Native QA) -->
    {indexableLocales.map((locale) => (
      <link
        rel="alternate"
        hreflang={locale}
        href={new URL(getLocalizedPath(pathWithoutLang, locale), Astro.site)}
      />
    ))}
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(getLocalizedPath(pathWithoutLang, 'en'), Astro.site)}
    />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Self-hosted fonts: Cormorant Garamond + Inter (GDPR — no third-party requests) -->
    <link rel="preload" href="/fonts/files/cormorant-garamond-400-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/files/inter-400-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="stylesheet" href="/fonts/fonts.css" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Floriente Cattery" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />

    <title>{title}</title>

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Floriente Cattery",
      "description": "Boutique cattery specializing in Oriental Shorthair and Siamese cats. WCF registered. Kyiv Region, Ukraine.",
      "url": "https://florientecattery.com",
      "logo": "https://florientecattery.com/images/floriente_dark_navy_transparent.webp",
      "image": "https://florientecattery.com/images/cats/sebastian-main.webp",
      "telephone": "+380931884422",
      "email": "info@florientecattery.com",
      "address": {
        "@type": "PostalAddress",
        "addressRegion": "Kyiv Region",
        "addressCountry": "UA"
      },
      "sameAs": [
        "https://www.instagram.com/floriente_orientals_cattery",
        "https://www.facebook.com/elvira.naurzalina",
        "https://www.tiktok.com/@floriente_cattery"
      ]
    })} />
    <slot name="head" />

    {cfAnalyticsToken && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token":"${cfAnalyticsToken}"}`}
      />
    )}
  </head>
  <body class="min-h-screen bg-warm-white text-dark flex flex-col overflow-x-hidden">
    <Header lang={lang} />
    <main class="flex-1 pt-20">
      <slot />
    </main>
    <Footer lang={lang} />
    <GlobalLightbox />
  </body>
</html>
