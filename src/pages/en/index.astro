---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/utils';

const lang = 'en';
---

<BaseLayout
  title="Floriente Cattery — Oriental & Siamese Kittens"
  description="Boutique cattery in Kyiv region, Ukraine. Oriental Shorthair & Siamese kittens raised at home with love."
  lang={lang}
>
  <main class="max-w-4xl mx-auto px-6 py-16">
    <div class="text-center mb-16">
      <img
        src="/images/floriente_dark_navy_transparent.png"
        alt="Floriente Cattery logo"
        class="mx-auto mb-8 w-48"
      />
      <h1 class="mb-4 text-gold-dark">{t(lang, 'home.heroHeadline')}</h1>
      <p class="text-xl text-dark-soft">{t(lang, 'home.heroSubheadline')}</p>
    </div>

    <!-- Design Tokens Preview -->
    <section class="mb-16">
      <h2 class="mb-8 text-center">Design System</h2>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
        <div class="text-center">
          <div class="w-16 h-16 mx-auto rounded-full bg-warm-white border border-gray-light"></div>
          <p class="mt-2 text-sm">Warm White</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 mx-auto rounded-full bg-gold"></div>
          <p class="mt-2 text-sm">Gold</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 mx-auto rounded-full bg-dark"></div>
          <p class="mt-2 text-sm">Dark</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 mx-auto rounded-full bg-blue-soft"></div>
          <p class="mt-2 text-sm">Soft Blue</p>
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
        <div class="text-center">
          <div class="w-10 h-10 mx-auto rounded-full bg-status-available"></div>
          <p class="mt-2 text-sm">Available</p>
        </div>
        <div class="text-center">
          <div class="w-10 h-10 mx-auto rounded-full bg-status-reserved"></div>
          <p class="mt-2 text-sm">Reserved</p>
        </div>
        <div class="text-center">
          <div class="w-10 h-10 mx-auto rounded-full bg-status-home"></div>
          <p class="mt-2 text-sm">At New Home</p>
        </div>
        <div class="text-center">
          <div class="w-10 h-10 mx-auto rounded-full bg-status-evaluation"></div>
          <p class="mt-2 text-sm">Evaluation</p>
        </div>
      </div>

      <div class="space-y-4">
        <h1>Heading 1 — Cormorant Garamond</h1>
        <h2>Heading 2 — Serif elegance</h2>
        <h3>Heading 3 — Premium editorial</h3>
        <p>Body text — Inter, clean and readable. Floriente Cattery is a boutique cattery specializing in Oriental Shorthair and Siamese cats.</p>
        <p class="text-sm text-gray-medium">Caption text — small, muted</p>
      </div>
    </section>

    <footer class="text-center text-sm text-gray-medium border-t border-gray-light pt-8">
      <p>&copy; 2024–2026 {t(lang, 'footer.copyright')}</p>
      <p class="mt-1">{t(lang, 'footer.wcf')}</p>
    </footer>
  </main>
</BaseLayout>
