---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Page Not Found" lang="en">
  <div class="max-w-2xl mx-auto px-6 py-24 text-center">
    <p class="text-8xl mb-6">🐱</p>
    <h1 class="text-dark mb-4" id="heading-404">Page Not Found</h1>
    <p class="text-lg text-dark-soft mb-8" id="text-404">
      This kitten wandered off. The page you're looking for doesn't exist.
    </p>
    <a
      href="/en/"
      id="link-404"
      class="inline-block px-8 py-3 bg-gold text-warm-white font-medium rounded hover:bg-gold-dark transition-colors"
    >
      Back to Home
    </a>
  </div>
</BaseLayout>

<script>
  const isUk = window.location.pathname.startsWith('/uk');
  if (isUk) {
    const h = document.getElementById('heading-404');
    const p = document.getElementById('text-404');
    const a = document.getElementById('link-404');
    if (h) h.textContent = 'Сторінку не знайдено';
    if (p) p.textContent = 'Це кошеня втекло. Сторінки, яку ви шукаєте, не існує.';
    if (a) { a.textContent = 'На головну'; a.setAttribute('href', '/uk/'); }
    document.documentElement.lang = 'uk';
  }
</script>
