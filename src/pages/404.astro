---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Page Not Found" lang="en">
  <div class="max-w-2xl mx-auto px-6 py-24 text-center">
    <p class="text-8xl mb-6">🐱</p>
    <h1 class="text-dark mb-4" id="heading-404">Page Not Found</h1>
    <p class="text-lg text-dark-soft mb-8" id="text-404">
      This kitten wandered off. The page you're looking for doesn't exist.
    </p>
    <a
      href="/en/"
      id="link-404"
      class="inline-block px-8 py-3 bg-gold text-warm-white font-medium rounded hover:bg-gold-dark transition-colors"
    >
      Back to Home
    </a>
  </div>
</BaseLayout>

<script>
  const path = window.location.pathname;
  const langMatch = path.match(/^\/(en|uk|pl|de|ru)/);
  const lang = langMatch?.[1] || 'en';

  const texts: Record<string, { heading: string; text: string; link: string }> = {
    en: { heading: 'Page Not Found', text: "This kitten wandered off. The page you're looking for doesn't exist.", link: 'Back to Home' },
    uk: { heading: 'Сторінку не знайдено', text: 'Це кошеня втекло. Сторінки, яку ви шукаєте, не існує.', link: 'На головну' },
    pl: { heading: 'Strona nie znaleziona', text: 'Ten kociak uciekł. Strona, której szukasz, nie istnieje.', link: 'Strona główna' },
    de: { heading: 'Seite nicht gefunden', text: 'Dieses Kätzchen ist weggelaufen. Die Seite, die Sie suchen, existiert nicht.', link: 'Zur Startseite' },
    ru: { heading: 'Страница не найдена', text: 'Этот котёнок убежал. Страница, которую вы ищете, не существует.', link: 'На главную' },
  };

  const t = texts[lang] || texts['en'];
  const h = document.getElementById('heading-404');
  const p = document.getElementById('text-404');
  const a = document.getElementById('link-404');
  if (h) h.textContent = t.heading;
  if (p) p.textContent = t.text;
  if (a) { a.textContent = t.link; a.setAttribute('href', `/${lang}/`); }
  document.documentElement.lang = lang;
</script>
