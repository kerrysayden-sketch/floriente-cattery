---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/family/HeroSection.astro';
import AlumniGallery from '../../components/family/AlumniGallery.astro';
import TestimonialsSection from '../../components/family/TestimonialsSection.astro';
import { t, createLangStaticPaths } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

export const getStaticPaths = createLangStaticPaths;

const { lang } = Astro.props as { lang: Lang };
---

<BaseLayout
  title={t(lang, 'pages.family.title')}
  description={t(lang, 'pages.family.description')}
  lang={lang}
>
  <div class="scroll-fade">
    <HeroSection lang={lang} />
  </div>
  <div class="scroll-fade">
    <TestimonialsSection lang={lang} />
  </div>
  <div class="scroll-fade">
    <AlumniGallery lang={lang} />
  </div>
</BaseLayout>

<script>
  import '../../scripts/scroll-fade';
</script>
