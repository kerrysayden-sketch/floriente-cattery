---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import StatusBadge from '../../../components/cats/StatusBadge.astro';
import { t, getLocalizedPath, locales } from '../../../i18n/utils';
import type { Lang } from '../../../i18n/utils';
import { fetchKittens } from '../../../lib/storyblok';
import type { KittenData } from '../../../lib/storyblok';

export async function getStaticPaths() {
  let kittens: KittenData[] = [];
  try {
    kittens = await fetchKittens();
  } catch {
    return [];
  }

  return locales.flatMap((lang) =>
    kittens.map((kitten) => ({
      params: { lang, slug: kitten.slug },
      props: { lang, kitten },
    }))
  );
}

const { lang, kitten } = Astro.props as { lang: Lang; kitten: KittenData };
const photoUrl = kitten.photos?.filename || '/images/floriente_dark_navy_transparent.webp';
const description = lang === 'uk' ? kitten.description_uk : kitten.description_en;
const breedFull = kitten.breed === 'OSH' ? 'Oriental Shorthair' : 'Siamese';
---

<BaseLayout
  title={`${kitten.name} - Floriente Cattery`}
  description={description || `${kitten.name}, ${breedFull} kitten`}
  lang={lang}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-medium mb-8">
      <a href={getLocalizedPath('/', lang)} class="hover:text-gold">{t(lang, 'nav.home')}</a>
      <span class="mx-2">/</span>
      <a href={getLocalizedPath('/kittens/', lang)} class="hover:text-gold">{t(lang, 'nav.kittens')}</a>
      <span class="mx-2">/</span>
      <span class="text-dark">{kitten.name}</span>
    </nav>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-14">
      <!-- Photo -->
      <div>
        <div class="relative aspect-square rounded-lg overflow-hidden bg-gray-light/50">
          <img src={photoUrl} alt={kitten.name} class="w-full h-full object-cover" />
          <div class="absolute top-4 left-4">
            <StatusBadge status={kitten.status} lang={lang} />
          </div>
        </div>

        {kitten.gallery && kitten.gallery.length > 0 && (
          <div class="grid grid-cols-4 gap-2 mt-4">
            {kitten.gallery.map((item: any) => (
              <div class="aspect-square rounded overflow-hidden bg-gray-light/50">
                <img
                  src={item.image?.filename || ''}
                  alt={item.caption || kitten.name}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Info -->
      <div>
        <h1 class="text-3xl md:text-4xl text-dark mb-4">{kitten.name}</h1>

        <dl class="space-y-3 mb-8">
          <div class="flex">
            <dt class="w-32 text-sm text-gray-medium">{t(lang, 'kittens.fieldBreed')}</dt>
            <dd class="text-sm text-dark">{breedFull}</dd>
          </div>
          <div class="flex">
            <dt class="w-32 text-sm text-gray-medium">{t(lang, 'kittens.fieldColor')}</dt>
            <dd class="text-sm text-dark">{kitten.color}</dd>
          </div>
          <div class="flex">
            <dt class="w-32 text-sm text-gray-medium">{t(lang, 'kittens.fieldSex')}</dt>
            <dd class="text-sm text-dark">{kitten.sex === 'male' ? '♂ ' + t(lang, 'kittens.male') : '♀ ' + t(lang, 'kittens.female')}</dd>
          </div>
          {kitten.dob && (
            <div class="flex">
              <dt class="w-32 text-sm text-gray-medium">{t(lang, 'kittens.fieldBorn')}</dt>
              <dd class="text-sm text-dark">{kitten.dob}</dd>
            </div>
          )}
          {kitten.father && (
            <div class="flex">
              <dt class="w-32 text-sm text-gray-medium">{t(lang, 'kittens.fieldFather')}</dt>
              <dd class="text-sm">
                <a href={getLocalizedPath(`/our-cats/${kitten.father}/`, lang)} class="text-gold hover:text-gold-dark">{kitten.father}</a>
              </dd>
            </div>
          )}
          {kitten.mother && (
            <div class="flex">
              <dt class="w-32 text-sm text-gray-medium">{t(lang, 'kittens.fieldMother')}</dt>
              <dd class="text-sm">
                <a href={getLocalizedPath(`/our-cats/${kitten.mother}/`, lang)} class="text-gold hover:text-gold-dark">{kitten.mother}</a>
              </dd>
            </div>
          )}
        </dl>

        {kitten.price && kitten.status === 'available' && (
          <div class="mb-8 p-4 bg-gold/5 border border-gold/20 rounded-lg">
            <p class="text-2xl font-serif text-gold">€{kitten.price}</p>
            <p class="text-xs text-gray-medium mt-1">{t(lang, 'kittens.priceIncludes')}</p>
          </div>
        )}

        {description && (
          <p class="text-dark-soft leading-relaxed mb-8">{description}</p>
        )}

        <a
          href={getLocalizedPath('/how-to-buy/', lang)}
          class="inline-block px-8 py-3.5 bg-gold text-warm-white font-medium rounded hover:bg-gold-dark transition-colors text-sm uppercase tracking-wider"
        >
          {t(lang, 'home.ctaReserve')}
        </a>
      </div>
    </div>

    {/* Watch Me Grow */}
    {kitten.watch_me_grow && kitten.watch_me_grow.length > 0 && (
      <section class="mt-16 md:mt-24">
        <h2 class="text-center mb-10">{t(lang, 'kittens.watchMeGrow')}</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
          {kitten.watch_me_grow
            .sort((a: any, b: any) => (a.week || 0) - (b.week || 0))
            .map((entry: any) => (
              <div class="text-center">
                <div class="aspect-square rounded-lg overflow-hidden bg-gray-light/50 mb-2">
                  <img
                    src={entry.photo?.filename || ''}
                    alt={`Week ${entry.week}`}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
                <p class="text-xs font-medium text-dark">
                  {t(lang, 'kittens.weekLabel')} {entry.week}
                </p>
                {entry.note && <p class="text-xs text-gray-medium">{entry.note}</p>}
              </div>
            ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
