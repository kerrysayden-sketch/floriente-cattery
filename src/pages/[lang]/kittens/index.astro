---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import KittenCard from '../../../components/cats/KittenCard.astro';
import { t, createLangStaticPaths, getLocalizedPath } from '../../../i18n/utils';
import type { Lang } from '../../../i18n/utils';
import { fetchKittens } from '../../../lib/storyblok';

export const getStaticPaths = createLangStaticPaths;

const { lang } = Astro.props as { lang: Lang };

let allKittens: any[] = [];
try {
  allKittens = await fetchKittens();
} catch {
  // CMS unavailable
}
---

<BaseLayout
  title={t(lang, 'pages.kittens.title')}
  lang={lang}
  noindex
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <h1 class="text-center text-gold-dark mb-12">{t(lang, 'nav.kittens')}</h1>

    {allKittens.length > 0 ? (
      <>
        {/* Filters */}
        <div id="kitten-filters" class="flex flex-wrap gap-3 justify-center mb-10">
          <button data-filter="all" class="filter-btn active px-4 py-2 rounded-full text-sm font-medium border border-gold bg-gold text-warm-white transition-colors">
            {lang === 'en' ? 'All' : 'Усі'}
          </button>
          <button data-filter="available" class="filter-btn px-4 py-2 rounded-full text-sm font-medium border border-gray-light text-dark-soft hover:border-gold hover:text-gold transition-colors">
            {lang === 'en' ? 'Available' : 'Доступні'}
          </button>
          <button data-filter="reserved" class="filter-btn px-4 py-2 rounded-full text-sm font-medium border border-gray-light text-dark-soft hover:border-gold hover:text-gold transition-colors">
            {lang === 'en' ? 'Reserved' : 'Зарезервовані'}
          </button>
        </div>

        {/* Grid */}
        <div id="kitten-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {allKittens.map((kitten) => <KittenCard kitten={kitten} lang={lang} />)}
        </div>

        {/* Empty filter state */}
        <div id="filter-empty" class="hidden text-center py-16">
          <p class="text-dark-soft text-lg">{t(lang, 'home.kittensEmpty')}</p>
        </div>
      </>
    ) : (
      <div class="text-center py-16 max-w-lg mx-auto">
        <div class="w-20 h-20 mx-auto mb-6 rounded-full bg-gray-light/50 flex items-center justify-center">
          <svg class="w-10 h-10 text-gold/40" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9" />
          </svg>
        </div>
        <p class="text-dark-soft text-lg mb-2">{t(lang, 'home.kittensEmpty')}</p>
        <p class="text-gray-medium text-sm mb-8">{t(lang, 'home.kittensWaitlist')}</p>
        <a
          href={getLocalizedPath('/how-to-buy/', lang)}
          class="inline-block px-8 py-3 bg-gold text-warm-white font-medium rounded hover:bg-gold-dark transition-colors text-sm uppercase tracking-wider"
        >
          {t(lang, 'home.kittensJoinWaitlist')}
        </a>
      </div>
    )}
  </div>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const grid = document.getElementById('kitten-grid');
  const empty = document.getElementById('filter-empty');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');

      // Update active button
      buttons.forEach((b) => {
        b.classList.remove('active', 'bg-gold', 'text-warm-white', 'border-gold');
        b.classList.add('border-gray-light', 'text-dark-soft');
      });
      btn.classList.add('active', 'bg-gold', 'text-warm-white', 'border-gold');
      btn.classList.remove('border-gray-light', 'text-dark-soft');

      // Filter cards
      if (!grid) return;
      const cards = grid.querySelectorAll('[data-status]');
      let visibleCount = 0;

      cards.forEach((card) => {
        const el = card as HTMLElement;
        if (filter === 'all' || el.dataset.status === filter) {
          el.style.display = '';
          visibleCount++;
        } else {
          el.style.display = 'none';
        }
      });

      if (empty) {
        empty.classList.toggle('hidden', visibleCount > 0);
      }
    });
  });
</script>
