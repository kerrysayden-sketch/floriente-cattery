---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { t, createLangStaticPaths, getLocalizedPath } from '../../../i18n/utils';
import type { Lang } from '../../../i18n/utils';
import { fetchKittens } from '../../../lib/storyblok';

export const getStaticPaths = createLangStaticPaths;

const { lang } = Astro.props as { lang: Lang };

let allKittens: any[] = [];
try {
  allKittens = await fetchKittens();
} catch {
  // CMS unavailable
}

const currentKittens = allKittens.filter((k) => k.status !== 'at_new_home');
const pastKittens = allKittens.filter((k) => k.status === 'at_new_home');

// ── Static litter data (source: Запрос материалов для Эльвиры - ответы.docx) ──
const litterA = [
  { name: 'Salma', full: 'Al Muad\'Dib Salma Ole Lukhoye', photo: '/images/kittens/litter-a/salma.jpg', sex: 'female', breed: 'Oriental Shorthair', color: 'Black spotted tabby' },
  { name: 'Milky', full: 'Alt Milky Ole Lukhoye', photo: '/images/kittens/litter-a/milky.jpg', sex: 'male', breed: 'Siamese', color: 'Chocolate point' },
  { name: 'Astra', full: 'Astra Shakhty Ole Lukhoye', photo: '/images/kittens/litter-a/astra.jpg', sex: 'female', breed: 'Oriental Shorthair', color: 'Black' },
  { name: 'Asya', full: 'Asya Ole Lukhoye', photo: '/images/kittens/litter-a/asya.jpg', sex: 'female', breed: 'Oriental Shorthair', color: 'Black spotted tabby' },
  { name: 'Axel', full: 'Axel Cornelius Ole Lukhoye', photo: '/images/kittens/litter-a/axel.jpg', sex: 'male', breed: 'Oriental Shorthair', color: 'Black spotted tabby' },
];

const litterB = [
  { name: 'Bantik', full: 'Bantik Ole Lukhoye', photo: '/images/kittens/litter-b/bantik.jpg', sex: 'male', breed: 'Siamese', color: 'Seal point' },
  { name: 'Barbie', full: 'Barbie Ole Lukhoye', photo: '/images/kittens/litter-b/barbie.jpg', sex: 'female', breed: 'Oriental Shorthair', color: 'Chocolate spotted tabby' },
  { name: 'Bars', full: 'Bars Ole Lukhoye', photo: '/images/kittens/litter-b/bars.jpg', sex: 'male', breed: 'Siamese', color: 'Seal point' },
  { name: 'Barton', full: 'Barton Ole Lukhoye', photo: '/images/kittens/litter-b/barton.jpg', sex: 'male', breed: 'Oriental Shorthair', color: 'Chocolate' },
  { name: 'Bead', full: 'Bead Ole Lukhoye', photo: '/images/kittens/litter-b/bead.jpg', sex: 'female', breed: 'Oriental Shorthair', color: 'Black spotted tabby' },
  { name: 'Bella', full: 'Bella Ole Lukhoye', photo: null, sex: 'female', breed: 'Siamese', color: 'Seal point' },
  { name: 'Benjamin', full: 'Benjamin Ole Lukhoye', photo: '/images/kittens/litter-b/benjamin.jpg', sex: 'male', breed: 'Oriental Shorthair', color: 'Black spotted tabby' },
  { name: 'Bill', full: 'Bill Ole Lukhoye', photo: '/images/kittens/litter-b/bill.jpg', sex: 'male', breed: 'Siamese', color: 'Seal point' },
  { name: 'Buddy', full: 'Buddy Ole Lukhoye', photo: '/images/kittens/litter-b/buddy.jpg', sex: 'male', breed: 'Oriental Shorthair', color: 'Black spotted tabby' },
];

const badgeLabel = lang === 'en' ? 'At New Home' : 'У новому домі';
const litterATitle = lang === 'en' ? 'Litter "A"' : 'Помiт «A»';
const litterBTitle = lang === 'en' ? 'Litter "B"' : 'Помiт «Б»';

const pageSubtitle = lang === 'en'
  ? 'Each of our 14 kittens grew up surrounded by love and found a family that was just right for them'
  : 'Кожне з наших 14 кошенят виросло в любові та знайшло родину, яка підходить саме йому';

const litterAMeta = lang === 'en'
  ? 'Born January 16, 2024 · Parents: Sebastian & Simona · 5 kittens'
  : 'Народилися 16 січня 2024 · Батьки: Sebastian & Simona · 5 кошенят';

const litterBMeta = lang === 'en'
  ? 'Born July 25, 2024 · Parents: Sebastian & Simona · 9 kittens'
  : 'Народилися 25 липня 2024 · Батьки: Sebastian & Simona · 9 кошенят';

const waitlistText = lang === 'en'
  ? 'Interested in a kitten from our future litters?'
  : 'Цікавить кошеня з наших майбутніх помiтів?';
const hiText = lang === 'en' ? "Hi, I'm" : 'Привіт, я';
---

<BaseLayout
  title={t(lang, 'pages.kittens.title')}
  description={t(lang, 'pages.kittens.description')}
  lang={lang}
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <h1 class="text-center text-gold-dark mb-4">{t(lang, 'nav.kittens')}</h1>
    <p class="text-center text-gray-medium mb-12 md:mb-16 max-w-2xl mx-auto">{pageSubtitle}</p>

    {/* ── CMS kittens (future litters) ── */}
    {currentKittens.length > 0 && (
      <>
        <div id="kitten-filters" class="flex flex-wrap gap-2 justify-center mb-4">
          <span class="text-xs text-gray-medium uppercase tracking-wider mr-2 self-center">{lang === 'en' ? 'Status:' : 'Статус:'}</span>
          <button data-filter="status" data-value="all" class="filter-btn active px-3 py-1.5 rounded-full text-xs font-medium border border-gold bg-gold text-warm-white transition-colors">
            {lang === 'en' ? 'All' : 'Усі'}
          </button>
          <button data-filter="status" data-value="available" class="filter-btn px-3 py-1.5 rounded-full text-xs font-medium border border-gray-light text-dark-soft hover:border-gold hover:text-gold transition-colors">
            {lang === 'en' ? 'Available' : 'Доступні'}
          </button>
          <button data-filter="status" data-value="reserved" class="filter-btn px-3 py-1.5 rounded-full text-xs font-medium border border-gray-light text-dark-soft hover:border-gold hover:text-gold transition-colors">
            {lang === 'en' ? 'Reserved' : 'Зарезервовані'}
          </button>
        </div>
        <div id="kitten-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-6 mb-16">
          {currentKittens.map((kitten) => (
            <a href={getLocalizedPath(`/kittens/${kitten.slug}/`, lang)} class="kitten-card text-center group" data-status={kitten.status}>
              <div class="relative mx-auto w-36 h-36 sm:w-40 sm:h-40 md:w-44 md:h-44 mb-3">
                <div class="w-full h-full rounded-full overflow-hidden border-2 border-gray-200 group-hover:border-gold/40 transition-colors duration-300 shadow-sm">
                  <img src={kitten.photos?.filename} alt={kitten.name} class="w-full h-full object-cover" loading="lazy" />
                </div>
                <span class={`absolute top-0 left-0 inline-flex items-center px-2.5 py-1 rounded-full text-[11px] font-semibold text-warm-white shadow-sm ${kitten.status === 'available' ? 'bg-emerald-500' : kitten.status === 'reserved' ? 'bg-amber-500' : 'bg-status-home'}`}>
                  {kitten.status === 'available' ? (lang === 'en' ? 'Available' : 'Доступний') : kitten.status === 'reserved' ? (lang === 'en' ? 'Reserved' : 'Зарезервований') : badgeLabel}
                </span>
              </div>
              <h3 class="text-lg md:text-xl font-serif text-dark-soft">{hiText} <strong class="text-dark">{kitten.name}</strong></h3>
              <p class="text-xs text-gray-medium mt-0.5">{kitten.breed || 'Oriental Shorthair'} {kitten.sex === 'male' ? (lang === 'en' ? 'Male' : 'Кіт') : (lang === 'en' ? 'Female' : 'Кішка')}</p>
            </a>
          ))}
        </div>
      </>
    )}

    {/* ── Litter A ── */}
    <section class="mb-14 md:mb-20">
      <div class="flex items-center gap-4 mb-2">
        <h2 class="text-2xl md:text-3xl text-gold-dark whitespace-nowrap">{litterATitle}</h2>
        <div class="flex-1 h-px bg-gray-light"></div>
      </div>
      <p class="text-sm text-gray-medium mb-8">{litterAMeta}</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-10">
        {litterA.map((kitten) => (
          <div class="text-center group">
            <div class="relative mx-auto w-40 h-40 sm:w-44 sm:h-44 md:w-48 md:h-48 mb-3">
              <div class="w-full h-full rounded-full overflow-hidden border-2 border-gray-200 group-hover:border-gold/40 group-hover:shadow-md transition-all duration-300 shadow-sm">
                <img
                  src={kitten.photo}
                  alt={kitten.full}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
              </div>
              <span class="absolute top-0 left-0 inline-flex items-center px-3.5 py-1.5 rounded-full text-sm font-bold text-warm-white bg-status-home shadow-sm">
                {badgeLabel}
              </span>
            </div>
            <h3 class="text-lg md:text-xl font-serif text-dark-soft">
              {hiText} <strong class="text-dark">{kitten.name}</strong>
              <span class={`ml-1.5 text-lg font-bold ${kitten.sex === 'male' ? 'text-blue-400' : 'text-pink-400'}`}>{kitten.sex === 'male' ? '♂' : '♀'}</span>
            </h3>
            <p class="text-xs text-gray-medium mt-1 leading-tight">{kitten.breed}. {kitten.sex === 'male' ? (lang === 'en' ? 'Male' : 'Кіт') : (lang === 'en' ? 'Female' : 'Кішка')}</p>
            <p class="text-[11px] text-gray-300 mt-0.5 leading-tight">{kitten.full}</p>
          </div>
        ))}
      </div>
    </section>

    {/* ── Litter B ── */}
    <section class="mb-14 md:mb-20">
      <div class="flex items-center gap-4 mb-2">
        <h2 class="text-2xl md:text-3xl text-gold-dark whitespace-nowrap">{litterBTitle}</h2>
        <div class="flex-1 h-px bg-gray-light"></div>
      </div>
      <p class="text-sm text-gray-medium mb-8">{litterBMeta}</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-10">
        {litterB.map((kitten) => (
          <div class="text-center group">
            <div class="relative mx-auto w-40 h-40 sm:w-44 sm:h-44 md:w-48 md:h-48 mb-3">
              <div class="w-full h-full rounded-full overflow-hidden border-2 border-gray-200 group-hover:border-gold/40 group-hover:shadow-md transition-all duration-300 shadow-sm">
                {kitten.photo ? (
                  <img
                    src={kitten.photo}
                    alt={kitten.full}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-full bg-warm-white flex items-center justify-center">
                    <img
                      src="/images/floriente_dark_navy_transparent.png"
                      alt="Floriente Cattery"
                      class="w-16 h-16 opacity-20"
                    />
                  </div>
                )}
              </div>
              <span class="absolute top-0 left-0 inline-flex items-center px-3.5 py-1.5 rounded-full text-sm font-bold text-warm-white bg-status-home shadow-sm">
                {badgeLabel}
              </span>
            </div>
            <h3 class="text-lg md:text-xl font-serif text-dark-soft">
              {hiText} <strong class="text-dark">{kitten.name}</strong>
              <span class={`ml-1.5 text-lg font-bold ${kitten.sex === 'male' ? 'text-blue-400' : 'text-pink-400'}`}>{kitten.sex === 'male' ? '♂' : '♀'}</span>
            </h3>
            <p class="text-xs text-gray-medium mt-1 leading-tight">{kitten.breed}. {kitten.sex === 'male' ? (lang === 'en' ? 'Male' : 'Кіт') : (lang === 'en' ? 'Female' : 'Кішка')}</p>
            <p class="text-[11px] text-gray-300 mt-0.5 leading-tight">{kitten.full}</p>
          </div>
        ))}
      </div>
    </section>

    {/* ── CMS past kittens (if any in Storyblok) ── */}
    {pastKittens.length > 0 && (
      <section class="mb-14 md:mb-20 pt-12 border-t border-gray-light">
        <h2 class="text-lg text-gray-medium mb-8">{lang === 'en' ? 'Previous Litters' : 'Попередні помiти'}</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
          {pastKittens.map((kitten) => (
            <a
              href={getLocalizedPath(`/kittens/${kitten.slug}/`, lang)}
              class="block rounded-lg overflow-hidden bg-warm-white border border-gray-light hover:border-gold/30 transition-colors"
            >
              <div class="aspect-square overflow-hidden bg-gray-light/30">
                {kitten.photos?.filename ? (
                  <img src={kitten.photos.filename} alt={kitten.name} class="w-full h-full object-cover opacity-80" loading="lazy" />
                ) : (
                  <div class="w-full h-full flex items-center justify-center">
                    <span class="text-gray-medium text-xs">{kitten.name}</span>
                  </div>
                )}
              </div>
              <div class="p-3">
                <p class="text-sm font-medium text-dark">{kitten.name}</p>
                <p class="text-xs text-gray-medium">{kitten.color}</p>
                {kitten.owner_name && (
                  <p class="text-xs text-gold mt-1">{lang === 'en' ? 'New home:' : 'Нова домівка:'} {kitten.owner_country}</p>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {/* ── Waitlist CTA ── */}
    <div class="text-center py-10 bg-gold/5 rounded-2xl border border-gold/10">
      <p class="text-dark-soft text-lg mb-4">{waitlistText}</p>
      <a
        href={getLocalizedPath('/contact/', lang)}
        class="inline-block px-8 py-3 bg-gold text-warm-white font-medium rounded hover:bg-gold-dark transition-colors text-sm uppercase tracking-wider"
      >
        {t(lang, 'home.kittensJoinWaitlist')}
      </a>
    </div>
  </div>
</BaseLayout>

<script>
  const grid = document.getElementById('kitten-grid');
  const empty = document.getElementById('filter-empty');

  const activeFilters = { status: 'all', breed: 'all', sex: 'all' };

  function applyFilters() {
    if (!grid) return;
    const cards = grid.querySelectorAll('[data-status]');
    let visibleCount = 0;

    cards.forEach((card) => {
      const el = card as HTMLElement;
      const matchStatus = activeFilters.status === 'all' || el.dataset.status === activeFilters.status;
      const matchBreed = activeFilters.breed === 'all' || el.dataset.breed === activeFilters.breed;
      const matchSex = activeFilters.sex === 'all' || el.dataset.sex === activeFilters.sex;

      if (matchStatus && matchBreed && matchSex) {
        el.style.display = '';
        visibleCount++;
      } else {
        el.style.display = 'none';
      }
    });

    if (empty) {
      empty.classList.toggle('hidden', visibleCount > 0);
    }
  }

  document.querySelectorAll('.filter-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const filterType = btn.getAttribute('data-filter') as keyof typeof activeFilters;
      const value = btn.getAttribute('data-value') || 'all';

      activeFilters[filterType] = value;

      const siblings = document.querySelectorAll(`[data-filter="${filterType}"]`);
      siblings.forEach((b) => {
        b.classList.remove('active', 'bg-gold', 'text-warm-white', 'border-gold');
        b.classList.add('border-gray-light', 'text-dark-soft');
      });
      btn.classList.add('active', 'bg-gold', 'text-warm-white', 'border-gold');
      btn.classList.remove('border-gray-light', 'text-dark-soft');

      applyFilters();
    });
  });
</script>
