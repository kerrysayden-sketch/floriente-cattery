---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CatCard from '../../../components/cats/CatCard.astro';
import { t, createLangStaticPaths, getLocalizedPath } from '../../../i18n/utils';
import type { Lang } from '../../../i18n/utils';
import { fetchCats, getCatsByRole } from '../../../lib/storyblok';

export const getStaticPaths = createLangStaticPaths;

const { lang } = Astro.props as { lang: Lang };

let allCats: any[] = [];
try {
  allCats = await fetchCats();
} catch (e) {
  // CMS unavailable — show empty state
}

const kings = getCatsByRole(allCats, 'king');
const queens = getCatsByRole(allCats, 'queen');
const retired = getCatsByRole(allCats, 'retired');
---

<BaseLayout
  title={t(lang, 'pages.ourCats.title')}
  lang={lang}
  noindex
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <h1 class="text-center text-gold-dark mb-4">{t(lang, 'nav.ourCats')}</h1>
    <p class="text-center text-dark-soft max-w-2xl mx-auto mb-16">
      {lang === 'en'
        ? 'Meet the cats behind Floriente Cattery. Each one is health-tested, titled, and most importantly — a beloved family member.'
        : 'Познайомтеся з котами розплідника Floriente. Кожен з них — протестований на здоров\'я, титулований та, найголовніше, улюблений член родини.'}
    </p>

    {/* Queens */}
    {queens.length > 0 && (
      <section class="mb-16">
        <h2 class="mb-8">{lang === 'en' ? 'Our Queens' : 'Наші кішки'}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {queens.map((cat) => <CatCard cat={cat} lang={lang} />)}
        </div>
      </section>
    )}

    {/* Kings */}
    {kings.length > 0 && (
      <section class="mb-16">
        <h2 class="mb-8">{lang === 'en' ? 'Our Kings' : 'Наші коти'}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {kings.map((cat) => <CatCard cat={cat} lang={lang} />)}
        </div>
      </section>
    )}

    {/* Retired */}
    {retired.length > 0 && (
      <section class="mb-16">
        <h2 class="text-lg mb-6 text-gray-medium">{lang === 'en' ? 'Retired' : 'На відпочинку'}</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
          {retired.map((cat) => <CatCard cat={cat} lang={lang} size="small" />)}
        </div>
      </section>
    )}

    {/* Empty state */}
    {allCats.length === 0 && (
      <div class="text-center py-16">
        <p class="text-dark-soft text-lg">{t(lang, 'pages.comingSoon')}</p>
      </div>
    )}

    {/* CTAs */}
    <div class="flex flex-col sm:flex-row gap-4 justify-center mt-12">
      <a
        href={getLocalizedPath('/kittens/', lang)}
        class="inline-block px-8 py-3 bg-gold text-warm-white font-medium rounded hover:bg-gold-dark transition-colors text-sm uppercase tracking-wider text-center"
      >
        {t(lang, 'home.ctaMeetKittens')}
      </a>
      <a
        href={getLocalizedPath('/how-to-buy/', lang)}
        class="inline-block px-8 py-3 border border-gold text-gold font-medium rounded hover:bg-gold hover:text-warm-white transition-colors text-sm uppercase tracking-wider text-center"
      >
        {t(lang, 'home.ctaReserve')}
      </a>
    </div>
  </div>
</BaseLayout>

<script>
  import '../../../scripts/scroll-fade';
</script>
