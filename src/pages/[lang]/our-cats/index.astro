---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CatGallery from '../../../components/cats/CatGallery.astro';
import { t, createLangStaticPaths, getLocalizedPath } from '../../../i18n/utils';
import type { Lang } from '../../../i18n/utils';

export const getStaticPaths = createLangStaticPaths;

const { lang } = Astro.props as { lang: Lang };

// Cat data from certificates + Elvira's document
const cats = [
  {
    id: 'sebastian',
    name: 'Sebastian (Seba)',
    fullName: 'Sebastian Ole Lukhoye',
    role: 'king' as const,
    titles: 'Grand Inter-Champion (GIC)',
    breed: 'Oriental Shorthair',
    color: lang === 'en' ? 'Black spotted tabby' : 'Чорний плямистий таббі',
    ems: 'OSH n 24',
    dob: '2022-01-27',
    breeder: 'Stasiyuk Olena',
    pedigree: 'UA-0136-PKPK 4/2022/OSH/LO',
    mainPhoto: '/images/cats/sebastian-main.jpg',
    gallery: [
      { src: '/images/cats/sebastian-catshow.jpg', label: lang === 'en' ? 'Cat Show — GIC title' : 'Виставка — титул GIC' },
      { src: '/images/cats/sebastian-3.jpg', label: lang === 'en' ? 'Resting on the blanket' : 'Відпочиває на пледі' },
      { src: '/images/cats/sebastian-4.jpg', label: lang === 'en' ? 'Sleeping on his favourite armchair' : 'Спить на улюбленому кріслі' },
      { src: '/images/cats/sebastian-5.jpg', label: lang === 'en' ? 'Always nearby' : 'Завжди поруч' },
    ],
    description_en: `Seba is a serious man. Started as a boy, grew into something more — composed, dignified, with presence. But in private, with just mom or dad around, he can be gentle and affectionate. As long as nobody's watching.\n\nHe has a secret. He'll quietly sneak over to the toy pile, pick one up, toss it around, play. But the moment I reach for a camera — it's over. "Me? Playing? No, nothing like that happened. Nope, wasn't me. Just passing through." Real men don't play. That's why videos of Seba are rare. He always knows when he's being filmed.\n\nJust a serious guy. That's it.`,
    description_uk: `Себа — серйозний чоловік. З юного хлопця сформувався самостійний кіт із благородним характером. Наодинці з мамою чи татом може бути ніжним і ласкавим. Головне — щоб ніхто не бачив.\n\nВ нього є секрет. Тихенько приходить до дитячих іграшок, бере одну, підкидує, грає. Але варто мені взяти камеру — все. «Я? Грався? Ні, нічого такого. Не-не-не, це не я. Просто повз проходив». Хлопці не танцюють. Тому відео з Себою — велика рідкість. Він завжди знає, коли його знімають.\n\nПросто серйозний хлопець. Все.`,
  },
  {
    id: 'simona',
    name: 'Simona (Sima)',
    fullName: 'Belly Dance Simona',
    role: 'queen' as const,
    titles: 'Grand Inter-Champion (GIC)',
    breed: 'Oriental Shorthair',
    color: lang === 'en' ? 'Blue spotted tabby' : 'Блакитний плямистий таббі',
    ems: 'OSH a 24',
    dob: '2023-03-04',
    breeder: 'Mukha Anna',
    pedigree: 'PCFC 2024/0171/OSH',
    mainPhoto: '/images/cats/simona-main.jpg',
    gallery: [
      { src: '/images/cats/simona-catshow.jpg', label: lang === 'en' ? 'Cat Show — GIC title' : 'Виставка — титул GIC' },
      { src: '/images/cats/simona-5.jpg', label: lang === 'en' ? 'Expecting kittens' : 'В очікуванні потомства' },
      { src: '/images/cats/simona-4.jpg', label: lang === 'en' ? 'Girl\'s photoshoot' : 'Фотосесія дівчини' },
      { src: '/images/cats/simona-3.jpg', label: lang === 'en' ? 'Nap time' : 'Час дрімати' },
    ],
    description_en: `Sima is our home inspector. We call her "the German" — everything in her world runs on a strict schedule. Morning starts by the wood stove, stretching out while the fire warms her bones. She melts. Then she sits down to work with me and stays until evening. At bedtime, she's the enforcer: if we don't go upstairs on time, Sima runs to us crying with the most dramatic notes. The schedule is being violated! Immediately!\n\nShe's also a talker. She'll tell you everything: where she went, what she did, what she thinks about it. Used the litter box — she'll report it and won't leave you alone until dad cleans it. Left her at grandma's — she'll recount her entire day down to the minute: who she played with, what she was up to. Going to the bathroom — she's coming with you. Always.\n\nVigilant, vocal, and full of personality.`,
    description_uk: `Сіма — наш домашній контролер. Ми називаємо її «німець»: у неї все чітко за розкладом. Зранку — прогріти кісточки біля печки на дровах, поки чоловік розтоплює. Млює. Потім сідає зі мною працювати, і так до вечора. Увечері — суворий контроль відбою: якщо вчасно не йдемо нагору спати, Сіма біжить і кричить з трагічними нотами. Графік порушується! Терміново!\n\nА ще Сіма балакучка. Розповість тобі все: що робила, куди ходила, що про це думає. Сходила в туалет — доповість і не відчепиться, поки тато не прибере. Залишили у бабусі — перекаже весь день до хвилинки: з ким бігала, чим займалася. Ідеш у ванну — вона йде з тобою. Завжди.\n\nПильна, голосиста і з характером.`,
  },
  {
    id: 'halva',
    name: 'Helding (Halva)',
    fullName: 'Helding Ole Lukhoye',
    role: 'queen' as const,
    titles: '',
    breed: 'Oriental Shorthair',
    color: lang === 'en' ? 'Chocolate' : 'Шоколадний',
    ems: 'OSH b',
    dob: '2025-11-15',
    breeder: '',
    pedigree: '',
    mainPhoto: '/images/cats/halva-main.jpg',
    gallery: [
      { src: '/images/cats/halva-2.jpg', label: lang === 'en' ? 'Photoshoot with flowers' : 'Фотосесія із квітками' },
      { src: '/images/cats/halva-3.jpg', label: lang === 'en' ? 'Sweet dreams' : 'Солодкий сон' },
      { src: '/images/cats/halva-4.jpg', label: lang === 'en' ? 'Wrapped in a cozy blanket' : 'Загорнулась у затишний плед' },
      { src: '/images/cats/halva-5.jpg', label: lang === 'en' ? 'Warming up in the sun' : 'Гріємось на сонечку' },
    ],
    description_en: `Halva came from far away. We waited for her a long time.\n\nWe call her our little parrot. Sima settles between your legs, Seba sits at your feet — Halva needs to climb onto your shoulder. As high as possible. Full parrot mode. She's still little, still growing — but already a beauty. Our long-awaited girl. Our little parrot.`,
    description_uk: `Халва приїхала здалеку. Ми чекали на неї довго.\n\nНазиваємо її попугайчик. Сіма сідає між ніг, Себа — внизу біля ніг, а Халві треба вилізти на саме плече. Якомога вище. Режим папуги. Вона ще маленька, росте — але вже красуня. Довгоочікувана наша. Попугайчик.`,
  },
];

const roleLabels = {
  queen: lang === 'en' ? 'Queen' : 'Кішка',
  king: lang === 'en' ? 'King' : 'Кіт',
};
---

<BaseLayout
  title={t(lang, 'pages.ourCats.title')}
  description={t(lang, 'pages.ourCats.description')}
  lang={lang}
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <!-- Header -->
    <div class="text-center mb-16 md:mb-24">
      <h1 class="text-dark mb-4">{t(lang, 'nav.ourCats')}</h1>
      <p class="text-dark-soft max-w-2xl mx-auto">
        {lang === 'en'
          ? 'Meet the cats behind Floriente Cattery. Each one is health-tested, titled, and most importantly — a beloved family member.'
          : 'Познайомтеся з котами розплідника Floriente. Кожен з них — протестований на здоров\'я, титулований та, найголовніше, улюблений член родини.'}
      </p>
    </div>

    {/* Cat blocks */}
    {cats.map((cat, index) => {
      const reversed = index % 2 === 1;
      const description = lang === 'en' ? cat.description_en : cat.description_uk;
      const paragraphs = description.split('\n\n');
      const isFirst = index === 0;

      return (
        <section
          id={cat.id}
          class:list={[
            'mb-14 md:mb-20',
            index > 0 && 'pt-10 md:pt-14 border-t border-gray-light/30',
          ]}
        >
          {/* Role label */}
          <p class:list={[
            'text-xs font-semibold uppercase tracking-[0.2em] text-gold mb-6 md:mb-8 text-center',
            !isFirst && 'scroll-fade',
          ]}>
            {roleLabels[cat.role]}
          </p>

          {/* Main content: photo + info */}
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-start max-w-5xl mx-auto">
            {/* Photo */}
            <div
              class:list={[
                'overflow-hidden shadow-lg group',
                !isFirst && (reversed ? 'scroll-fade-right' : 'scroll-fade-left'),
                reversed ? 'md:order-2' : 'md:order-1',
              ]}
            >
              <div class="aspect-[4/5] overflow-hidden bg-gray-light/20" data-lightbox-gallery={`cat-${cat.id}`}>
                <img
                  src={cat.mainPhoto}
                  alt={cat.name}
                  class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700"
                  loading={isFirst ? 'eager' : 'lazy'}
                />
              </div>
            </div>

            {/* Info panel */}
            <div
              class:list={[
                'flex flex-col justify-center space-y-6',
                !isFirst && (reversed ? 'scroll-fade-left' : 'scroll-fade-right'),
                reversed ? 'md:order-1' : 'md:order-2',
              ]}
            >
              {/* Name + title */}
              <div>
                <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl text-dark mb-2">{cat.name}</h2>
                {cat.titles && (
                  <span class="inline-block px-3 py-1 bg-accent-gold/10 text-accent-gold text-xs font-semibold uppercase tracking-wider">
                    {cat.titles} — World Cat Federation
                  </span>
                )}
              </div>

              {/* Description from Elvira */}
              <div class="space-y-4">
                {paragraphs.map((p: string) => (
                  <p class="text-dark-soft text-sm md:text-base leading-relaxed">{p}</p>
                ))}
              </div>

              {/* Stats */}
              <div class="grid grid-cols-2 gap-3 pt-2">
                <div class="border-l-2 border-accent-gold/30 pl-3">
                  <p class="text-[10px] text-gray-medium uppercase tracking-wider">{lang === 'en' ? 'Breed' : 'Порода'}</p>
                  <p class="text-sm text-dark font-medium">{cat.breed}</p>
                </div>
                <div class="border-l-2 border-accent-gold/30 pl-3">
                  <p class="text-[10px] text-gray-medium uppercase tracking-wider">{lang === 'en' ? 'Color' : 'Окрас'}</p>
                  <p class="text-sm text-dark font-medium">{cat.color}</p>
                </div>
                <div class="border-l-2 border-accent-gold/30 pl-3">
                  <p class="text-[10px] text-gray-medium uppercase tracking-wider">EMS</p>
                  <p class="text-sm text-dark font-medium">{cat.ems}</p>
                </div>
                {cat.titles && (
                  <div class="border-l-2 border-accent-gold/30 pl-3">
                    <p class="text-[10px] text-gray-medium uppercase tracking-wider">{lang === 'en' ? 'Title' : 'Титул'}</p>
                    <p class="text-sm text-dark font-medium">{cat.titles}</p>
                  </div>
                )}
              </div>

              {/* Health testing placeholder */}
              <div class="bg-warm-white border border-gray-light/50 p-4 mt-2">
                <div class="flex items-start gap-3">
                  <span class="text-lg">🔬</span>
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-wider text-dark mb-1">
                      {lang === 'en' ? 'Health Testing' : 'Тестування здоров\'я'}
                    </p>
                    <p class="text-xs text-gray-medium">
                      {lang === 'en'
                        ? 'Results expected — Summer 2026'
                        : 'Результати очікуються — літо 2026'}
                    </p>
                    <p class="text-xs text-gray-medium">
                      {lang === 'en'
                        ? 'Laboratories: NeoVetLab, Genomia (Czech Republic)'
                        : 'Лабораторії: NeoVetLab, Genomia (Чехія)'}
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          {/* Mini gallery */}
          <div class="mt-8 md:mt-12 max-w-5xl mx-auto scroll-fade">
            <CatGallery photos={cat.gallery} catName={cat.name} galleryId={cat.id} />
          </div>
        </section>
      );
    })}

    {/* CTAs */}
    <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8 md:mt-12 pt-12 border-t border-gray-light/30">
      <a
        href={getLocalizedPath('/kittens/', lang)}
        class="inline-block px-8 py-3 bg-gold text-warm-white font-medium hover:bg-gold-dark transition-colors text-sm uppercase tracking-wider text-center"
      >
        {t(lang, 'home.ctaMeetKittens')}
      </a>
      <a
        href={getLocalizedPath('/how-to-buy/', lang)}
        class="inline-block px-8 py-3 border border-gold text-gold font-medium hover:bg-gold hover:text-warm-white transition-colors text-sm uppercase tracking-wider text-center"
      >
        {t(lang, 'home.ctaReserve')}
      </a>
    </div>
  </div>
</BaseLayout>

<style>
  .scroll-fade-left {
    opacity: 0;
    transform: translateX(-40px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .scroll-fade-right {
    opacity: 0;
    transform: translateX(40px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .scroll-fade-left.visible,
  .scroll-fade-right.visible {
    opacity: 1;
    transform: translateX(0);
  }
</style>

<script>
  import '../../../scripts/scroll-fade';

  // Directional scroll animations
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.05 }
  );

  document.querySelectorAll('.scroll-fade-left, .scroll-fade-right').forEach((el) => {
    observer.observe(el);
  });
</script>
