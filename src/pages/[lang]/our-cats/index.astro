---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CatShowcase from '../../../components/cats/CatShowcase.astro';
import CatCard from '../../../components/cats/CatCard.astro';
import { t, createLangStaticPaths, getLocalizedPath } from '../../../i18n/utils';
import type { Lang } from '../../../i18n/utils';
import { fetchCats, getCatsByRole } from '../../../lib/storyblok';
import type { CatData } from '../../../lib/storyblok';

export const getStaticPaths = createLangStaticPaths;

const { lang } = Astro.props as { lang: Lang };

let allCats: CatData[] = [];
try {
  allCats = await fetchCats();
} catch (e) {
  // CMS unavailable — use fallback only
}

// Fallback/override data for cats not yet in CMS or needing local photos
const localOverrides: Record<string, Partial<CatData> & { localPhoto?: string }> = {
  'simona': {
    localPhoto: '/images/cats/simona-main.jpg',
  },
  'sebastian': {
    localPhoto: '/images/cats/sebastian-main.jpg',
  },
};

// Halva fallback (not yet in Storyblok)
const halvaFallback: CatData & { localPhoto?: string } = {
  slug: 'halva',
  name: 'Halva',
  breed: 'OSH',
  sex: 'female',
  color: 'Chocolate',
  ems_code: 'OSH b',
  dob: '2025-11-15',
  titles: '',
  role: 'queen',
  photos: null,
  description_en: 'Our youngest queen, Halva brings warmth and playful energy to Floriente. With her rich chocolate coat and expressive eyes, she embodies the best of Oriental elegance. Currently preparing for her show debut.',
  description_uk: 'Наша наймолодша кішка, Халва привносить тепло та грайливу енергію у Floriente. Завдяки насиченому шоколадному забарвленню та виразним очам, вона втілює найкраще орієнтальної елегантності. Наразі готується до свого виставкового дебюту.',
  health_tests: [],
  gallery: [],
  pedigree_pdf: null,
  localPhoto: '/images/cats/halva-main.jpg',
};

// Only show these cats in showcase (exclude Salma and any others)
const showcaseSlugs = ['simona', 'sebastian', 'halva'];

// Merge CMS data with local overrides, filter to showcase only
const enrichedCats = allCats
  .filter(cat => showcaseSlugs.includes(cat.slug))
  .map(cat => ({
    ...cat,
    ...localOverrides[cat.slug],
  }));

// Add Halva if not in CMS
if (!enrichedCats.find(c => c.slug === 'halva')) {
  enrichedCats.push(halvaFallback);
}

const kings = enrichedCats.filter(c => c.role === 'king' && c.sex === 'male');
const queens = enrichedCats.filter(c => c.role === 'queen' || c.sex === 'female');
const retired = enrichedCats.filter(c => c.role === 'retired');

// Ordered showcase: all cats in alternating layout
// Queens first, then Kings
const showcaseCats = [...queens, ...kings];
---

<BaseLayout
  title={t(lang, 'pages.ourCats.title')}
  description={t(lang, 'pages.ourCats.description')}
  lang={lang}
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <h1 class="text-center text-gold-dark mb-4">{t(lang, 'nav.ourCats')}</h1>
    <p class="text-center text-dark-soft max-w-2xl mx-auto mb-16">
      {lang === 'en'
        ? 'Meet the cats behind Floriente Cattery. Each one is health-tested, titled, and most importantly — a beloved family member.'
        : 'Познайомтеся з котами розплідника Floriente. Кожен з них — протестований на здоров\'я, титулований та, найголовніше, улюблений член родини.'}
    </p>

    {/* Alternating showcase for each cat */}
    {showcaseCats.map((cat, index) => (
      <CatShowcase cat={cat} lang={lang} reversed={index % 2 === 1} isFirst={index === 0} />
    ))}

    {/* Retired */}
    {retired.length > 0 && (
      <section class="mb-16">
        <h2 class="text-lg mb-6 text-gray-medium">{lang === 'en' ? 'Retired' : 'На відпочинку'}</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
          {retired.map((cat) => <CatCard cat={cat} lang={lang} size="small" />)}
        </div>
      </section>
    )}

    {/* Empty state */}
    {showcaseCats.length === 0 && retired.length === 0 && (
      <div class="text-center py-16">
        <p class="text-dark-soft text-lg">{t(lang, 'pages.comingSoon')}</p>
      </div>
    )}

    {/* CTAs */}
    <div class="flex flex-col sm:flex-row gap-4 justify-center mt-12">
      <a
        href={getLocalizedPath('/kittens/', lang)}
        class="inline-block px-8 py-3 bg-gold text-warm-white font-medium rounded hover:bg-gold-dark transition-colors text-sm uppercase tracking-wider text-center"
      >
        {t(lang, 'home.ctaMeetKittens')}
      </a>
      <a
        href={getLocalizedPath('/how-to-buy/', lang)}
        class="inline-block px-8 py-3 border border-gold text-gold font-medium rounded hover:bg-gold hover:text-warm-white transition-colors text-sm uppercase tracking-wider text-center"
      >
        {t(lang, 'home.ctaReserve')}
      </a>
    </div>
  </div>
</BaseLayout>

<script>
  import '../../../scripts/scroll-fade';
</script>
