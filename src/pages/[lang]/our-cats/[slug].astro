---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Lightbox from '../../../components/ui/Lightbox.astro';
import { t, getLocalizedPath, locales } from '../../../i18n/utils';
import type { Lang } from '../../../i18n/utils';
import { fetchCats, fetchKittens } from '../../../lib/storyblok';
import type { CatData } from '../../../lib/storyblok';

export async function getStaticPaths() {
  // Local gallery overrides — applies to any cat (CMS or local) by slug
  const localGalleries: Record<string, string[]> = {
    'halva': [
      '/images/cats/halva-2.jpg',
      '/images/cats/halva-3.jpg',
      '/images/cats/halva-4.jpg',
      '/images/cats/halva-5.jpg',
      '/images/cats/halva-6.jpg',
      '/images/cats/halva-7.jpg',
    ],
    'sebastian': [
      '/images/cats/sebastian-2.jpg',
      '/images/cats/sebastian-3.jpg',
    ],
  };

  // Local main photo overrides for CMS cats
  const localPhotos: Record<string, string> = {
    'sebastian': '/images/cats/sebastian-main.jpg',
    'simona': '/images/cats/simona-main.jpg',
  };

  // Local fallback for cats not yet in Storyblok
  const localCats: (CatData & { localPhoto?: string; localGallery?: string[] })[] = [
    {
      slug: 'halva',
      name: 'Halva',
      breed: 'OSH',
      sex: 'female',
      color: 'Chocolate',
      ems_code: 'OSH b',
      dob: '2025-11-15',
      titles: '',
      role: 'queen',
      photos: null,
      description_en: 'Our youngest queen, Halva brings warmth and playful energy to Floriente. With her rich chocolate coat and expressive eyes, she embodies the best of Oriental elegance. Currently preparing for her show debut.',
      description_uk: 'Наша наймолодша кішка, Халва привносить тепло та грайливу енергію у Floriente. Завдяки насиченому шоколадному забарвленню та виразним очам, вона втілює найкраще орієнтальської елегантності. Наразі готується до свого виставкового дебюту.',
      health_tests: [],
      gallery: [],
      pedigree_pdf: null,
      localPhoto: '/images/cats/halva-main.jpg',
      localGallery: localGalleries['halva'],
    },
  ];

  let cats: CatData[] = [];
  try {
    cats = await fetchCats();
  } catch {}

  // Merge CMS cats + local cats (avoid duplicates)
  const cmsSlugs = new Set(cats.map(c => c.slug));
  const allCats = [...cats, ...localCats.filter(c => !cmsSlugs.has(c.slug))];

  return locales.flatMap((lang) =>
    allCats.map((cat) => ({
      params: { lang, slug: cat.slug },
      props: {
        lang,
        cat: {
          ...cat,
          // Apply local photo override for CMS cats
          localPhoto: localPhotos[cat.slug] || (cat as any).localPhoto,
          // Apply local gallery override (extends/replaces CMS gallery)
          localGallery: localGalleries[cat.slug] || (cat as any).localGallery || [],
        },
      },
    }))
  );
}

const { lang, cat } = Astro.props as { lang: Lang; cat: CatData & { localPhoto?: string; localGallery?: string[] } };
const photoUrl = cat.localPhoto || cat.photos?.filename || '/images/floriente_dark_navy_transparent.png';
const hasPhoto = !!cat.localPhoto || !!cat.photos?.filename;
const description = lang === 'uk' ? cat.description_uk : cat.description_en;
const breedFull = cat.breed === 'OSH' ? 'Oriental Shorthair' : 'Siamese';

// Fetch offspring (kittens whose father or mother matches this cat's slug)
let offspring: any[] = [];
try {
  const allKittens = await fetchKittens();
  offspring = allKittens.filter((k) => k.father === cat.slug || k.mother === cat.slug);
} catch {}
---

<BaseLayout
  title={`${cat.name} — Floriente Cattery`}
  description={description || `${cat.name}, ${breedFull} ${cat.color}`}
  lang={lang}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-medium mb-8">
      <a href={getLocalizedPath('/', lang)} class="hover:text-gold">{t(lang, 'nav.home')}</a>
      <span class="mx-2">/</span>
      <a href={getLocalizedPath('/our-cats/', lang)} class="hover:text-gold">{t(lang, 'nav.ourCats')}</a>
      <span class="mx-2">/</span>
      <span class="text-dark">{cat.name}</span>
    </nav>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-14">
      <!-- Photo -->
      <div>
        <div class="aspect-[4/5] rounded-lg overflow-hidden bg-gray-light/50 cursor-pointer">
          <img
            src={photoUrl}
            alt={cat.name}
            class="w-full h-full object-cover"
            data-lightbox
          />
        </div>

        {/* Gallery thumbnails (CMS) */}
        {cat.gallery && cat.gallery.length > 0 && (
          <div class="grid grid-cols-4 gap-2 mt-4">
            {cat.gallery.map((item: any) => (
              <div class="aspect-square rounded overflow-hidden bg-gray-light/50">
                <img
                  src={item.image?.filename || ''}
                  alt={item.caption || cat.name}
                  class="w-full h-full object-cover cursor-pointer hover:opacity-80 transition-opacity"
                  loading="lazy"
                  data-lightbox
                />
              </div>
            ))}
          </div>
        )}
        {/* Gallery thumbnails (local fallback) */}
        {cat.localGallery && cat.localGallery.length > 0 && (
          <div class="grid grid-cols-4 gap-2 mt-4">
            {cat.localGallery.map((src: string) => (
              <div class="aspect-square rounded overflow-hidden bg-gray-light/50">
                <img
                  src={src}
                  alt={cat.name}
                  class="w-full h-full object-cover cursor-pointer hover:opacity-80 transition-opacity"
                  loading="lazy"
                  data-lightbox
                />
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Info -->
      <div>
        <div class="mb-2">
          {cat.titles && (
            <span class="inline-block px-3 py-1 bg-gold/10 text-gold text-sm font-medium rounded mb-3">
              {cat.titles}
            </span>
          )}
        </div>
        <h1 class="text-3xl md:text-4xl text-gold-dark mb-2">{cat.name}</h1>
        <p class="text-gray-medium text-lg mb-6">
          {cat.role === 'king' ? (lang === 'en' ? 'King' : 'Кіт') : cat.role === 'queen' ? (lang === 'en' ? 'Queen' : 'Кішка') : (lang === 'en' ? 'Retired' : 'На відпочинку')}
        </p>

        <!-- Details table -->
        <dl class="space-y-3 mb-8">
          <div class="flex">
            <dt class="w-32 text-sm text-gray-medium">{lang === 'en' ? 'Breed' : 'Порода'}</dt>
            <dd class="text-sm text-dark">{breedFull}</dd>
          </div>
          <div class="flex">
            <dt class="w-32 text-sm text-gray-medium">{lang === 'en' ? 'Color' : 'Колір'}</dt>
            <dd class="text-sm text-dark">{cat.color}</dd>
          </div>
          {cat.ems_code && (
            <div class="flex">
              <dt class="w-32 text-sm text-gray-medium">EMS</dt>
              <dd class="text-sm text-dark font-mono">{cat.ems_code}</dd>
            </div>
          )}
          {cat.dob && (
            <div class="flex">
              <dt class="w-32 text-sm text-gray-medium">{lang === 'en' ? 'Born' : 'Народження'}</dt>
              <dd class="text-sm text-dark">{cat.dob}</dd>
            </div>
          )}
          <div class="flex">
            <dt class="w-32 text-sm text-gray-medium">{lang === 'en' ? 'Sex' : 'Стать'}</dt>
            <dd class="text-sm text-dark">{cat.sex === 'male' ? (lang === 'en' ? 'Male' : 'Кіт') : (lang === 'en' ? 'Female' : 'Кішка')}</dd>
          </div>
        </dl>

        {/* Description */}
        {description && (
          <div class="mb-8">
            <p class="text-dark-soft leading-relaxed">{description}</p>
          </div>
        )}

        {/* Health Tests */}
        {cat.health_tests && cat.health_tests.length > 0 && (
          <div class="mb-8">
            <h3 class="text-lg font-serif mb-4">{lang === 'en' ? 'Health Tests' : 'Тести здоров\'я'}</h3>
            <div class="space-y-3">
              {cat.health_tests.map((test: any) => (
                <div class="flex items-center justify-between p-3 bg-gray-light/30 rounded">
                  <div>
                    <span class="text-sm font-medium text-dark">{test.test_name}</span>
                    {test.lab && <span class="text-xs text-gray-medium ml-2">({test.lab})</span>}
                  </div>
                  <div class="flex items-center gap-3">
                    <span class:list={[
                      'text-xs font-medium px-2 py-0.5 rounded',
                      test.result === 'normal' ? 'bg-status-available/10 text-status-available' : 'bg-status-reserved/10 text-status-reserved',
                    ]}>
                      {test.result === 'normal' ? 'Normal' : test.result}
                    </span>
                    {test.pdf?.filename && (
                      <a
                        href={test.pdf.filename}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-xs text-gold hover:text-gold-dark"
                      >
                        PDF
                      </a>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* Offspring */}
        {offspring.length > 0 && (
          <div class="mb-8">
            <h3 class="text-lg font-serif mb-4">{lang === 'en' ? 'Offspring' : 'Нащадки'}</h3>
            <div class="space-y-2">
              {offspring.map((kitten: any) => (
                <a
                  href={getLocalizedPath(`/kittens/${kitten.slug}/`, lang)}
                  class="flex items-center gap-3 p-3 bg-gray-light/30 rounded hover:bg-gray-light/50 transition-colors"
                >
                  {kitten.photos?.filename && (
                    <img src={kitten.photos.filename} alt={kitten.name} class="w-10 h-10 rounded-full object-cover" />
                  )}
                  <div>
                    <span class="text-sm font-medium text-dark">{kitten.name}</span>
                    <span class="text-xs text-gray-medium ml-2">{kitten.color}</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

        {/* CTAs */}
        <div class="flex flex-col sm:flex-row gap-3 mt-8">
          <a
            href={getLocalizedPath('/kittens/', lang)}
            class="inline-block px-6 py-3 bg-gold text-warm-white font-medium rounded hover:bg-gold-dark transition-colors text-sm uppercase tracking-wider text-center"
          >
            {t(lang, 'home.ctaMeetKittens')}
          </a>
          <a
            href={getLocalizedPath('/how-to-buy/', lang)}
            class="inline-block px-6 py-3 border border-gold text-gold font-medium rounded hover:bg-gold hover:text-warm-white transition-colors text-sm uppercase tracking-wider text-center"
          >
            {t(lang, 'home.ctaReserve')}
          </a>
        </div>
      </div>
    </div>
  </div>
  <Lightbox />
</BaseLayout>
