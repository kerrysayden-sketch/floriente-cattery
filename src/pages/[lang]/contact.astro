---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/contact/HeroSection.astro';
import MethodsSection from '../../components/contact/MethodsSection.astro';
import InfoSection from '../../components/contact/InfoSection.astro';
import { t, createLangStaticPaths } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

export const getStaticPaths = createLangStaticPaths;

const { lang } = Astro.props as { lang: Lang };
---

<BaseLayout
  title={t(lang, 'pages.contact.title')}
  description={t(lang, 'pages.contact.description')}
  lang={lang}
>
  <div class="scroll-fade">
    <HeroSection lang={lang} />
  </div>
  <div class="scroll-fade">
    <MethodsSection lang={lang} />
  </div>
  <div class="scroll-fade">
    <InfoSection lang={lang} />
  </div>
</BaseLayout>

<script>
  import '../../scripts/scroll-fade';
</script>
