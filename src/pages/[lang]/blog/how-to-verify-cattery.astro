---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { t, getLocalizedPath, createLangStaticPaths } from '../../../i18n/utils';
import type { Lang } from '../../../i18n/utils';

export const getStaticPaths = createLangStaticPaths;

const { lang } = Astro.props as { lang: Lang };

const title = lang === 'en'
  ? 'How to Verify a Legitimate Cattery: A Buyer\'s Checklist'
  : 'Як перевірити розплідник: чеклист покупця';

const description = lang === 'en'
  ? 'Don\'t fall for cat scams. Use this expert checklist to verify any cattery before sending money. Real credentials, real red flags, real protection.'
  : 'Не потрапте на шахраїв. Чеклист для перевірки будь-якого розплідника перед оплатою. Реальні документи, червоні прапорці, захист.';

const canonicalBase = 'https://florientecattery.com';
const canonicalUrl = `${canonicalBase}/${lang}/blog/how-to-verify-cattery/`;
const alternateEn = `${canonicalBase}/en/blog/how-to-verify-cattery/`;
const alternateUk = `${canonicalBase}/uk/blog/how-to-verify-cattery/`;
const ogImage = `${canonicalBase}/images/cats/sebastian-main.jpg`;
const publishDate = '2026-04-06';

// Article JSON-LD
const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "image": ogImage,
  "datePublished": publishDate,
  "dateModified": publishDate,
  "author": {
    "@type": "Organization",
    "name": "Floriente Cattery",
    "url": canonicalBase
  },
  "publisher": {
    "@type": "Organization",
    "name": "Floriente Cattery",
    "logo": {
      "@type": "ImageObject",
      "url": `${canonicalBase}/favicon-192.png`
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalUrl
  },
  "inLanguage": lang === 'en' ? 'en' : 'uk'
});
---

<BaseLayout
  title={`${title} — Floriente Cattery`}
  description={description}
  lang={lang}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={articleSchema} />
  </Fragment>

  <article class="py-16 md:py-24 px-4 sm:px-6">
    <div class="max-w-3xl mx-auto">
      <!-- Back link -->
      <a
        href={getLocalizedPath('/blog/', lang)}
        class="inline-flex items-center gap-2 text-sm text-gold hover:text-gold-dark transition-colors mb-8"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
        {lang === 'en' ? 'Back to Blog' : 'Назад до блогу'}
      </a>

      <!-- Header -->
      <header class="mb-12">
        <span class="text-xs uppercase tracking-wider text-gold font-semibold">
          {lang === 'en' ? 'Buyer\'s Guide' : 'Гід покупця'}
        </span>
        <h1 class="font-serif text-3xl md:text-4xl text-dark mt-2 mb-4">{title}</h1>
        <div class="flex items-center gap-4 text-sm text-gray-medium">
          <time datetime={publishDate}>{lang === 'en' ? 'April 2026' : 'Квітень 2026'}</time>
          <span>Floriente Cattery</span>
        </div>
      </header>

      <!-- Content -->
      <div class="prose prose-lg max-w-none text-dark-soft leading-relaxed
        [&_h2]:font-serif [&_h2]:text-dark [&_h2]:text-2xl [&_h2]:mt-10 [&_h2]:mb-4
        [&_h3]:font-serif [&_h3]:text-dark [&_h3]:text-xl [&_h3]:mt-8 [&_h3]:mb-3
        [&_p]:mb-6
        [&_a]:text-gold [&_a]:hover:text-gold-dark
        [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:mb-6
        [&_ol]:list-decimal [&_ol]:pl-6 [&_ol]:mb-6
        [&_blockquote]:border-l-4 [&_blockquote]:border-gold [&_blockquote]:pl-6 [&_blockquote]:italic
      ">
        {lang === 'en' ? (
          <Fragment>
            <p>
              Buying a purebred kitten online is risky. Every year, hundreds of people wire deposits to catteries that don't exist. The money vanishes. The kitten never arrives.
            </p>
            <p>
              But fake breeders are easy to spot - if you know what to look for. Real catteries leave a paper trail. Here's what to check before you send a single euro.
            </p>

            <h2>The 7-point verification checklist</h2>

            <h3>1. Check the cattery registration</h3>
            <p>
              Any cattery worth your money is registered with WCF (World Cat Federation), TICA, FIFe, or CFA. Ask for the number. Then go to the organization's website and verify it yourself. Takes two minutes.
            </p>
            <div class="bg-gold/5 border-l-4 border-gold p-4 my-6 not-prose">
              <p class="text-sm text-dark"><strong>Floriente Cattery:</strong> WCF Registration #50188-2025. Verify at <a href="https://wcf-online.de" target="_blank" rel="noopener" class="text-gold hover:text-gold-dark">wcf-online.de</a></p>
            </div>

            <h3>2. Ask for a video call</h3>
            <p>
              A real breeder will show you the kitten on camera - in their home, parents nearby. If they dodge the video call, make excuses, or send "new photos" instead - that's your answer. Move on.
            </p>
            <div class="bg-gold/5 border-l-4 border-gold p-4 my-6 not-prose">
              <p class="text-sm text-dark"><strong>Floriente Cattery:</strong> We offer video calls before reservation. You'll see the kitten, the parents, and our home.</p>
            </div>

            <h3>3. Verify health testing</h3>
            <p>
              Breeders who care test parents for genetic diseases before breeding. For Orientals and Siamese: PRA (progressive retinal atrophy), PK deficiency, blood type. Ask which lab ran the tests. If they can't name one, they probably didn't test.
            </p>
            <div class="bg-gold/5 border-l-4 border-gold p-4 my-6 not-prose">
              <p class="text-sm text-dark"><strong>Floriente Cattery:</strong> All parents tested at NeoVetLab and Genomia (Czech Republic). Results shared with buyers before reservation.</p>
            </div>

            <h3>4. Request the contract</h3>
            <p>
              No written contract = no deal. A contract should cover health guarantees, spay/neuter terms, return policy, and ownership transfer. If they say "we don't do contracts" - they're not a cattery, they're a seller.
            </p>
            <div class="bg-gold/5 border-l-4 border-gold p-4 my-6 not-prose">
              <p class="text-sm text-dark"><strong>Floriente Cattery:</strong> Full sales contract provided. Covers health guarantee, microchip, vaccination, pedigree, and post-adoption support.</p>
            </div>

            <h3>5. Check champion titles</h3>
            <p>
              Breeders love to mention titles. Champion, Grand Champion, International Champion - each one earned at official shows judged by licensed experts. Ask for proof. Titles are public record.
            </p>
            <div class="bg-gold/5 border-l-4 border-gold p-4 my-6 not-prose">
              <p class="text-sm text-dark"><strong>Floriente Cattery:</strong> Sebastian and Simona - Grand Inter-Champions (GIC), World Cat Federation. Cat show photos and certificates available on our website.</p>
            </div>

            <h3>6. Look for real owner reviews</h3>
            <p>
              Real names. Real photos of kittens in their new homes. Not stock images, not anonymous quotes. Ask the breeder to connect you with a previous buyer. Anyone who refuses has something to hide.
            </p>
            <div class="bg-gold/5 border-l-4 border-gold p-4 my-6 not-prose">
              <p class="text-sm text-dark"><strong>Floriente Cattery:</strong> 13 kittens in loving homes. Owner testimonials with photos on our homepage. We're happy to connect you with previous families.</p>
            </div>

            <h3>7. Know what's included in the price</h3>
            <p>
              Vaccinations, microchip, passport, pedigree, spay/neuter, food starter kit, adaptation guide. A serious breeder lists all of it upfront. If the price is vague or suspiciously low - walk away.
            </p>
            <div class="bg-gold/5 border-l-4 border-gold p-4 my-6 not-prose">
              <p class="text-sm text-dark"><strong>Floriente Cattery:</strong> Full breakdown on our <a href={getLocalizedPath('/how-to-buy/', lang)} class="text-gold hover:text-gold-dark">How to Buy</a> page - 8 items included with every kitten.</p>
            </div>

            <h2>Red flags: when to walk away</h2>
            <ul>
              <li><strong>100% prepayment required</strong> before you've seen the kitten on video</li>
              <li><strong>No registration number</strong> or refusal to share it</li>
              <li><strong>Stock photos</strong> instead of real photos of kittens and parents</li>
              <li><strong>Price significantly below market</strong> - Oriental/Siamese kittens from registered breeders cost €800-€1,500+ (pet class)</li>
              <li><strong>No contract offered</strong> or "we don't do contracts"</li>
              <li><strong>Pressure to decide quickly</strong> - "this kitten won't last" or "deposit today or lose it"</li>
              <li><strong>No social media presence</strong> - no Instagram, no Facebook, no history of activity</li>
            </ul>

            <h2>Before you send money, ask these seven questions</h2>
            <ol>
              <li>What's your cattery registration number? Which organization?</li>
              <li>Can we do a video call to see the kitten and parents?</li>
              <li>Which genetic tests have the parents passed? At which lab?</li>
              <li>Can I see the contract before committing?</li>
              <li>What titles do the parents have? Where can I verify?</li>
              <li>Can I talk to a previous buyer?</li>
              <li>What exactly is included in the price?</li>
            </ol>

            <p>
              A breeder who's done nothing wrong will answer all seven without flinching. Vague answers, stalling, or pushback? Trust your gut. Keep looking.
            </p>
          </Fragment>
        ) : (
          <Fragment>
            <p>
              Купівля породистого кошеняти онлайн - це ризик. Щороку сотні людей переказують гроші розплідникам, яких не існує. Завдаток зникає. Кошеня ніколи не приїжджає.
            </p>
            <p>
              Але фейкових заводчиків легко розпізнати - якщо знати, куди дивитися. Справжні розплідники залишають паперовий слід. Ось що перевірити, перш ніж надіслати хоча б одне євро.
            </p>

            <h2>Чеклист з 7 пунктів для перевірки</h2>

            <h3>1. Перевірте реєстрацію розплідника</h3>
            <p>
              Будь-який розплідник, вартий вашої уваги, зареєстрований у WCF (World Cat Federation), TICA, FIFe або CFA. Запитайте номер. Зайдіть на сайт організації та перевірте самі. Дві хвилини роботи.
            </p>
            <div class="bg-gold/5 border-l-4 border-gold p-4 my-6 not-prose">
              <p class="text-sm text-dark"><strong>Floriente Cattery:</strong> Реєстрація WCF #50188-2025. Перевірити на <a href="https://wcf-online.de" target="_blank" rel="noopener" class="text-gold hover:text-gold-dark">wcf-online.de</a></p>
            </div>

            <h3>2. Попросіть відеодзвінок</h3>
            <p>
              Справжній заводчик покаже вам кошеня на камеру - у себе вдома, з батьками поруч. Якщо відмовляють, шукають відмовки або надсилають «нові фото» замість відео - це вже відповідь. Йдіть далі.
            </p>
            <div class="bg-gold/5 border-l-4 border-gold p-4 my-6 not-prose">
              <p class="text-sm text-dark"><strong>Floriente Cattery:</strong> Ми пропонуємо відеодзвінки до бронювання. Ви побачите кошеня, батьків та наш дім.</p>
            </div>

            <h3>3. Перевірте тестування здоров'я</h3>
            <p>
              Заводчики, яким не все одно, тестують батьків на генетичні хвороби до в'язки. Для орієнталів та сіамських: PRA (прогресуюча атрофія сітківки), PK-дефіцит, група крові. Запитайте, яка лабораторія робила тести. Якщо не можуть назвати - скоріш за все, не тестували.
            </p>
            <div class="bg-gold/5 border-l-4 border-gold p-4 my-6 not-prose">
              <p class="text-sm text-dark"><strong>Floriente Cattery:</strong> Всі батьки протестовані в NeoVetLab та Genomia (Чехія). Результати надаються покупцям до бронювання.</p>
            </div>

            <h3>4. Запросіть договір</h3>
            <p>
              Немає письмового договору - немає угоди. Договір має покривати гарантії здоров'я, умови стерилізації, політику повернення, передачу права власності. Якщо кажуть «ми не працюємо з договорами» - це не розплідник, це продавець.
            </p>
            <div class="bg-gold/5 border-l-4 border-gold p-4 my-6 not-prose">
              <p class="text-sm text-dark"><strong>Floriente Cattery:</strong> Повний договір купівлі-продажу. Покриває гарантію здоров'я, мікрочіп, вакцинацію, родовід та підтримку після усиновлення.</p>
            </div>

            <h3>5. Перевірте титули</h3>
            <p>
              Заводчики люблять згадувати титули. Чемпіон, Гранд Чемпіон, Інтернаціональний Чемпіон - кожен заслуговується на офіційних виставках під оцінкою ліцензованих суддів. Просіть докази. Титули - публічна інформація.
            </p>
            <div class="bg-gold/5 border-l-4 border-gold p-4 my-6 not-prose">
              <p class="text-sm text-dark"><strong>Floriente Cattery:</strong> Sebastian та Simona - Гранд Інтер-Чемпіони (GIC), World Cat Federation. Фото з виставок та сертифікати на нашому сайті.</p>
            </div>

            <h3>6. Шукайте реальні відгуки</h3>
            <p>
              Реальні імена. Реальні фото кошенят у нових домівках. Не стокові картинки, не анонімні цитати. Попросіть заводчика з'єднати вас із попереднім покупцем. Хто відмовляє - має що приховувати.
            </p>
            <div class="bg-gold/5 border-l-4 border-gold p-4 my-6 not-prose">
              <p class="text-sm text-dark"><strong>Floriente Cattery:</strong> 13 кошенят у люблячих домівках. Відгуки власників з фото на нашій головній сторінці. Ми із задоволенням з'єднаємо вас з попередніми родинами.</p>
            </div>

            <h3>7. Зрозумійте, що входить у ціну</h3>
            <p>
              Вакцинації, мікрочіп, паспорт, родовід, стерилізація, стартовий набір корму, гід з адаптації. Серйозний заводчик перелічує все відкрито. Якщо ціна розмита або підозріло низька - тікайте.
            </p>
            <div class="bg-gold/5 border-l-4 border-gold p-4 my-6 not-prose">
              <p class="text-sm text-dark"><strong>Floriente Cattery:</strong> Повний перелік на нашій сторінці <a href={getLocalizedPath('/how-to-buy/', lang)} class="text-gold hover:text-gold-dark">Як придбати</a> - 8 пунктів включено з кожним кошеням.</p>
            </div>

            <h2>Червоні прапорці: коли варто відмовитися</h2>
            <ul>
              <li><strong>100% передоплата</strong> до того, як ви побачили кошеня на відео</li>
              <li><strong>Немає реєстраційного номера</strong> або відмова його надати</li>
              <li><strong>Стокові фото</strong> замість реальних фото кошенят та батьків</li>
              <li><strong>Ціна значно нижча за ринкову</strong> - орієнтальні/сіамські кошенята від зареєстрованих заводчиків коштують €800-€1,500+ (пет-клас)</li>
              <li><strong>Немає договору</strong> або «ми не працюємо з договорами»</li>
              <li><strong>Тиск на швидке рішення</strong> - «це кошеня довго не простоїть» або «завдаток сьогодні, інакше втратите»</li>
              <li><strong>Немає присутності в соцмережах</strong> - ні Instagram, ні Facebook, ні історії активності</li>
            </ul>

            <h2>Перед тим як надіслати гроші, задайте сім запитань</h2>
            <ol>
              <li>Який реєстраційний номер розплідника? В якій організації?</li>
              <li>Чи можемо зробити відеодзвінок, щоб побачити кошеня та батьків?</li>
              <li>Які генетичні тести пройшли батьки? В якій лабораторії?</li>
              <li>Чи можу побачити договір до зобов'язань?</li>
              <li>Які титули мають батьки? Де їх перевірити?</li>
              <li>Чи можу поговорити з попереднім покупцем?</li>
              <li>Що саме входить у ціну?</li>
            </ol>

            <p>
              Заводчик, якому нема чого приховувати, відповість на всі сім без вагань. Розмиті відповіді, затягування, опір? Довіряйте інтуїції. Шукайте далі.
            </p>
          </Fragment>
        )}
      </div>

      <!-- CTA -->
      <div class="mt-16 pt-12 border-t border-gray-light/50 text-center">
        <h3 class="font-serif text-xl text-dark mb-3">
          {lang === 'en' ? 'Ready to meet our kittens?' : 'Готові познайомитися з нашими кошенятами?'}
        </h3>
        <p class="text-dark-soft text-sm mb-6">
          {lang === 'en'
            ? 'We pass every point on this checklist. See for yourself.'
            : 'Ми проходимо кожен пункт цього чеклиста. Переконайтеся самі.'}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href={getLocalizedPath('/our-cats/', lang)}
            class="inline-block px-8 py-3 bg-gold text-warm-white font-medium hover:bg-gold-dark transition-colors text-sm uppercase tracking-wider"
          >
            {t(lang, 'nav.ourCats')}
          </a>
          <a
            href={getLocalizedPath('/how-to-buy/', lang)}
            class="inline-block px-8 py-3 border border-gold text-gold font-medium hover:bg-gold hover:text-warm-white transition-colors text-sm uppercase tracking-wider"
          >
            {t(lang, 'nav.howToBuy')}
          </a>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
