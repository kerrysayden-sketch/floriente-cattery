---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LegalContent from '../../components/legal/LegalContent.astro';
import { t, createLangStaticPaths } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

export const getStaticPaths = createLangStaticPaths;

const { lang } = Astro.props as { lang: Lang };
---

<BaseLayout
  title={t(lang, 'pages.legal.title')}
  description={t(lang, 'pages.legal.description')}
  lang={lang}
>
  <LegalContent lang={lang} />
</BaseLayout>
