---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/home/HeroSection.astro';
import TrustBar from '../../components/home/TrustBar.astro';
import KittensPreview from '../../components/home/KittensPreview.astro';
import AboutPreview from '../../components/home/AboutPreview.astro';
import FamilySection from '../../components/home/FamilySection.astro';
import { t, createLangStaticPaths } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

export const getStaticPaths = createLangStaticPaths;

const { lang } = Astro.props as { lang: Lang };
---

<BaseLayout
  title={t(lang, 'pages.index.title')}
  description={t(lang, 'pages.index.description')}
  lang={lang}
>
  <HeroSection lang={lang} />
  <TrustBar lang={lang} variant="A" />
  <div class="scroll-fade">
    <KittensPreview lang={lang} />
  </div>
  <div class="scroll-fade">
    <AboutPreview lang={lang} />
  </div>
  <div class="scroll-fade">
    <FamilySection lang={lang} />
  </div>
</BaseLayout>

<script>
  import '../../scripts/scroll-fade';
</script>
