---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, createLangStaticPaths } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

export const getStaticPaths = createLangStaticPaths;

const { lang } = Astro.props as { lang: Lang };
---

<BaseLayout
  title={t(lang, 'pages.index.title')}
  description={t(lang, 'pages.index.description')}
  lang={lang}
>
  <div class="max-w-4xl mx-auto px-6 py-16 text-center">
    <img
      src="/images/floriente_dark_navy_transparent.png"
      alt={t(lang, 'pages.logoAlt')}
      class="mx-auto mb-8 w-48"
    />
    <h1 class="mb-4 text-gold-dark">{t(lang, 'home.heroHeadline')}</h1>
    <p class="text-xl text-dark-soft">{t(lang, 'home.heroSubheadline')}</p>
  </div>
</BaseLayout>
