---
import { storyblokEditable } from '@storyblok/astro';

const { blok } = Astro.props;
---

<section {...storyblokEditable(blok)} class="py-20 text-center">
  <h1 class="font-heading text-4xl md:text-6xl text-navy">{blok.title}</h1>
  {blok.subtitle && <p class="mt-4 text-lg text-warm-gray">{blok.subtitle}</p>}
</section>
