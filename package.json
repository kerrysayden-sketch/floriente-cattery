{
  "name": "floriente-cattery",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": ". ./scripts/load-env.sh && astro dev",
    "build": ". ./scripts/load-env.sh && astro build",
    "preview": ". ./scripts/load-env.sh && astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "i18n:check": "node scripts/check-i18n.mjs",
    "test:smoke": "playwright test",
    "fonts:refresh": "curl -sA 'Mozilla/5.0' 'https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@300;400;500;600&display=swap' -o public/fonts/fonts.css && node scripts/build-fonts.mjs",
    "backup:storyblok": ". ./scripts/load-env.sh && node scripts/storyblok-backup.mjs"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.1",
    "@storyblok/astro": "^9.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.0.8",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@playwright/test": "^1.59.1",
    "typescript": "^5.9.3"
  }
}
